---
import { categoryMeta } from "../data/categoryMeta";
import { bannerVariants } from "../data/bannerVariants";

const { appStoreUrl = "#" } = Astro.props;

const componentId = `home-hero-${Math.random().toString(36).slice(2, 10)}`;

const heroVariant =
  bannerVariants.find((variant) =>
    /it.?s time to fly/i.test(`${variant.title ?? ""} ${variant.subtitle ?? ""}`)
  ) ?? bannerVariants[0];

const heroHasLogo = Boolean(heroVariant.logoAsset);

const slides = [
  {
    type: "variant",
    variant: heroVariant,
  },
  {
    type: "photo",
    src: "/home-banner-photo-1.png",
    alt: "Black and white home banner photo 1",
  },
  {
    type: "photo",
    src: "/home-banner-photo-2.png",
    alt: "Black and white home banner photo 2",
  },
];
---

<div class="homeHeroBanner" id={componentId}>
  <div class="homeHeroBanner__viewport">
    {slides.map((slide, slideIndex) => (
      <article
        class:list={[
          "homeHeroBanner__slide",
          slideIndex === 0 && "is-active",
        ]}
        data-slide
        aria-hidden={slideIndex === 0 ? "false" : "true"}
      >
        {slide.type === "variant" ? (
          <div class="heroBanner">
            <div
              class="heroBanner__card"
              data-stack-style={slide.variant.stackStyle}
              data-has-logo={heroHasLogo ? "true" : "false"}
            >
              <div class="heroBanner__copy">
                <div class="heroBanner__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M12 2.8l1.7 5.8 5.5 1.7-5.5 1.7-1.7 5.8-1.7-5.8-5.5-1.7 5.5-1.7L12 2.8z"></path>
                  </svg>
                </div>

                <div class="heroBanner__text">
                  <div class="heroBanner__headlineRow">
                    <h1 class="heroBanner__title">{slide.variant.title}</h1>

                    <div
                      class:list={[
                        "heroBanner__logoWrap",
                        !heroHasLogo && "is-hidden",
                      ]}
                    >
                      {slide.variant.logoAsset && (
                        <img
                          class="heroBanner__logo"
                          src={slide.variant.logoAsset}
                          alt={slide.variant.logoAlt ?? "FLY logo"}
                          loading="eager"
                          decoding="async"
                        />
                      )}
                    </div>
                  </div>

                  <p
                    class:list={[
                      "heroBanner__subtitle",
                      !slide.variant.subtitle && "is-hidden",
                    ]}
                  >
                    {slide.variant.subtitle}
                  </p>

                  <div class="heroBanner__actions">
                    <a class="heroBanner__appBtn" href={appStoreUrl}>
                      <span class="heroBanner__appBtnIcon" aria-hidden="true">←</span>
                      <span>Get the app</span>
                    </a>
                  </div>
                </div>
              </div>

              <div class="heroBanner__stack" aria-hidden="true">
                {slide.variant.rows.map((row, rowIndex) => (
                  <div class="heroBanner__row">
                    {row.map((key, colIndex) => (
                      <div
                        class="heroBanner__cube"
                        style={`--cube-color:${categoryMeta[key].color}; --delay:${rowIndex * 110 + colIndex * 46}ms;`}
                      >
                        <img
                          src={categoryMeta[key].icon}
                          alt=""
                          loading="eager"
                          decoding="async"
                        />
                      </div>
                    ))}
                  </div>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <div class="heroBanner heroBanner--photo">
            <div class="heroBanner__card heroBanner__card--photo">
              <img
                class="heroBanner__photo"
                src={slide.src}
                alt={slide.alt}
                loading="eager"
                decoding="async"
              />

              <div class="heroBanner__photoShade"></div>

              <div class="heroBanner__photoOverlay">
                <a class="heroBanner__appBtn heroBanner__appBtn--photo" href={appStoreUrl}>
                  <span class="heroBanner__appBtnIcon" aria-hidden="true">←</span>
                  <span>Get the app</span>
                </a>
              </div>
            </div>
          </div>
        )}
      </article>
    ))}
  </div>

  <div class="homeHeroBanner__dots" aria-label="Hero banner navigation">
    {slides.map((_, index) => (
      <button
        type="button"
        class:list={[
          "homeHeroBanner__dot",
          index === 0 && "is-active",
        ]}
        data-dot
        aria-label={`Go to banner ${index + 1}`}
        aria-pressed={index === 0 ? "true" : "false"}
      />
    ))}
  </div>
</div>

<script is:inline define:vars={{ componentId }}>
  (() => {
    const root = document.getElementById(componentId);
    if (!root) return;

    const slides = Array.from(root.querySelectorAll("[data-slide]"));
    const dots = Array.from(root.querySelectorAll("[data-dot]"));

    if (!slides.length || slides.length !== dots.length) return;

    let current = 0;
    let timer = null;
    const intervalMs = 7800;

    const showSlide = (nextIndex) => {
      current = nextIndex;

      slides.forEach((slide, index) => {
        const active = index === current;
        slide.classList.toggle("is-active", active);
        slide.setAttribute("aria-hidden", active ? "false" : "true");
      });

      dots.forEach((dot, index) => {
        const active = index === current;
        dot.classList.toggle("is-active", active);
        dot.setAttribute("aria-pressed", active ? "true" : "false");
      });
    };

    const stop = () => {
      if (timer) {
        window.clearInterval(timer);
        timer = null;
      }
    };

    const start = () => {
      stop();
      timer = window.setInterval(() => {
        showSlide((current + 1) % slides.length);
      }, intervalMs);
    };

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        showSlide(index);
        start();
      });
    });

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);

    showSlide(0);
    start();
  })();
</script>

<style is:global>
  .homeHeroBanner {
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
    position: relative;
    background: #fff;
  }

  .homeHeroBanner__viewport {
    position: relative;
    min-height: clamp(248px, 30vw, 352px);
  }

  .homeHeroBanner__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 360ms ease, visibility 360ms ease;
  }

  .homeHeroBanner__slide.is-active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .heroBanner {
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
    background: #fff;
  }

  .heroBanner__card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(20px, 3vw, 38px);
    min-height: clamp(248px, 30vw, 352px);
    padding: clamp(8px, 1.2vw, 14px) clamp(16px, 2.6vw, 30px);
    background: #fff;
  }

  .heroBanner__copy {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    column-gap: 18px;
    min-width: 0;
    align-self: center;
  }

  .heroBanner__icon {
    width: 56px;
    height: 56px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.045);
    border: 1px solid rgba(0, 0, 0, 0.05);
    margin-top: 4px;
    flex: 0 0 auto;
  }

  .heroBanner__icon svg {
    width: 18px;
    height: 18px;
    fill: rgba(11, 12, 16, 0.82);
  }

  .heroBanner__text {
    min-width: 0;
    max-width: 36rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .heroBanner__headlineRow {
    width: 100%;
    display: block;
  }

  .heroBanner__title {
    margin: 0;
    font-size: clamp(34px, 4.8vw, 70px);
    line-height: 0.96;
    letter-spacing: -1.5px;
    text-wrap: balance;
  }

  .heroBanner__subtitle {
    margin: 10px 0 0;
    max-width: 24ch;
    color: rgba(11, 12, 16, 0.66);
    font-size: clamp(17px, 1.75vw, 22px);
    line-height: 1.25;
    text-wrap: pretty;
  }

  .heroBanner__subtitle.is-hidden {
    display: none;
  }

  .heroBanner__logoWrap {
    margin-top: 14px;
    display: flex;
    align-items: center;
  }

  .heroBanner__logoWrap.is-hidden {
    display: none;
  }

  .heroBanner__logo {
    width: clamp(118px, 10vw, 164px);
    height: auto;
    display: block;
    object-fit: contain;
  }

  .heroBanner__actions {
    margin-top: 18px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .heroBanner__appBtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 44px;
    padding: 0 16px;
    border-radius: 999px;
    background: #0b0c10;
    color: #fff;
    border: 1px solid transparent;
    font-weight: 760;
    font-size: 14px;
    letter-spacing: 0.1px;
    transition: transform 0.18s ease, background 0.18s ease;
  }

  .heroBanner__appBtn:hover {
    transform: translateY(-1px);
    background: #000;
  }

  .heroBanner__appBtnIcon {
    font-size: 16px;
    line-height: 1;
  }

  .heroBanner__stack {
    align-self: center;
    width: fit-content;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 2px 8px;
  }

  .heroBanner__row {
    display: flex;
    gap: 6px;
  }

  .heroBanner__cube {
    width: 60px;
    height: 60px;
    border-radius: 18px;
    background: var(--cube-color);
    display: grid;
    place-items: center;
    flex: 0 0 60px;
    opacity: 0;
    transform: translate3d(0, -18px, 0) rotate(-5deg);
    will-change: transform, opacity;
  }

  .homeHeroBanner__slide.is-active .heroBanner__cube {
    animation: heroBannerDrop 700ms cubic-bezier(0.2, 0.82, 0.2, 1) both;
    animation-delay: var(--delay, 0ms);
  }

  .heroBanner__cube img {
    width: 58%;
    height: 58%;
    display: block;
    pointer-events: none;
    user-select: none;
  }

  .heroBanner__card[data-stack-style="fullBlock"] {
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(18px, 2.4vw, 28px);
  }

  .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__copy {
    align-self: center;
  }

  .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__text {
    max-width: 42rem;
  }

  .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__headlineRow {
    display: block;
    max-width: 34rem;
  }

  .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__headlineRow {
    display: flex;
    align-items: flex-end;
    gap: 18px;
    flex-wrap: nowrap;
    max-width: 40rem;
    overflow: visible;
  }

  .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__title {
    max-width: 7.6ch;
    flex: 0 1 auto;
    text-wrap: balance;
  }

  .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__logoWrap {
    margin: 0 0 0.5rem;
    flex: 0 0 auto;
    align-self: flex-end;
  }

  .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__logo {
    width: clamp(132px, 11vw, 176px);
  }

  .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__stack {
    justify-self: end;
    align-items: flex-start;
    max-width: 332px;
  }

  .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__row {
    justify-content: flex-start;
  }

  .heroBanner__card[data-stack-style="playfulRows"] {
    grid-template-columns: minmax(0, 0.96fr) auto;
    gap: clamp(18px, 2.8vw, 32px);
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__copy {
    justify-self: center;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__text {
    align-items: center;
    text-align: center;
    max-width: 30rem;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__subtitle {
    max-width: 23ch;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__stack {
    justify-self: end;
    align-items: center;
    max-width: 300px;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__row {
    justify-content: center;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__row:last-child {
    transform: translateX(-4px);
  }

  .heroBanner__card[data-stack-style="leftRise"] {
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(16px, 2.4vw, 26px);
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__stack {
    order: 1;
    justify-self: start;
    align-items: flex-start;
    max-width: 336px;
    padding-left: 0;
    padding-right: 0;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__row {
    justify-content: flex-start;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__copy {
    order: 2;
    justify-self: start;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__text {
    max-width: 28rem;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__title {
    max-width: 9.2ch;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__subtitle {
    max-width: 21ch;
  }

  .heroBanner__card--photo {
    position: relative;
    display: block;
    min-height: clamp(248px, 30vw, 352px);
    padding: 0;
    overflow: hidden;
    background: #f2f2f2;
  }

  .heroBanner__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .heroBanner__photoShade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0,0,0,0.04) 0%,
      rgba(0,0,0,0.08) 52%,
      rgba(0,0,0,0.20) 100%
    );
  }

  .heroBanner__photoOverlay {
    position: absolute;
    left: clamp(16px, 2.6vw, 30px);
    right: clamp(16px, 2.6vw, 30px);
    bottom: clamp(16px, 2.2vw, 24px);
    z-index: 2;
    display: flex;
    justify-content: flex-start;
    align-items: center;
  }

  .heroBanner__appBtn--photo {
    background: rgba(255, 255, 255, 0.92);
    color: #0b0c10;
  }

  .heroBanner__appBtn--photo:hover {
    background: #fff;
  }

  .homeHeroBanner__dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    padding-top: 16px;
  }

  .homeHeroBanner__dot {
    width: 9px;
    height: 9px;
    border: 0;
    border-radius: 999px;
    background: rgba(11, 12, 16, 0.18);
    padding: 0;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease, width 0.2s ease;
  }

  .homeHeroBanner__dot:hover {
    transform: scale(1.08);
  }

  .homeHeroBanner__dot.is-active {
    width: 24px;
    background: #0b0c10;
  }

  @keyframes heroBannerDrop {
    0% {
      opacity: 0;
      transform: translate3d(0, -18px, 0) rotate(-5deg);
    }
    55% {
      opacity: 1;
      transform: translate3d(0, 4px, 0) rotate(2deg);
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) rotate(0deg);
    }
  }

  @media (max-width: 980px) {
    .heroBanner__card {
      gap: clamp(16px, 2.8vw, 26px);
      padding-left: clamp(14px, 3vw, 22px);
      padding-right: clamp(14px, 3vw, 22px);
      min-height: clamp(236px, 28vw, 320px);
    }

    .heroBanner__cube {
      width: 56px;
      height: 56px;
      flex-basis: 56px;
      border-radius: 17px;
    }

    .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__headlineRow {
      max-width: 36rem;
      gap: 14px;
    }

    .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__title {
      max-width: 7.1ch;
    }

    .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__stack {
      max-width: 304px;
    }

    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__stack {
      max-width: 276px;
    }

    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__stack {
      max-width: 300px;
    }
  }

  @media (max-width: 860px) {
    .heroBanner__card,
    .heroBanner__card[data-stack-style="fullBlock"],
    .heroBanner__card[data-stack-style="playfulRows"],
    .heroBanner__card[data-stack-style="leftRise"] {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 24px;
      min-height: auto;
      padding-left: clamp(14px, 5vw, 24px);
      padding-right: clamp(14px, 5vw, 24px);
    }

    .heroBanner__copy,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__copy {
      order: 1;
      width: 100%;
      justify-self: stretch;
    }

    .heroBanner__text,
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__text,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__text {
      max-width: 100%;
      align-items: flex-start;
      text-align: left;
    }

    .heroBanner__subtitle,
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__subtitle,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__subtitle {
      max-width: 25ch;
    }

    .heroBanner__stack,
    .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__stack,
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__stack,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__stack {
      order: 2;
      width: 100%;
      max-width: 100%;
      align-items: center;
      justify-self: center;
      padding-left: 12px;
      padding-right: 12px;
    }

    .heroBanner__row,
    .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__row,
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__row,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__row {
      justify-content: center;
      width: 100%;
      flex-wrap: wrap;
      transform: none;
    }

    .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__headlineRow {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      max-width: 100%;
    }

    .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__title,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__title {
      max-width: 100%;
    }

    .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__logoWrap {
      margin: 0;
    }

    .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__logo {
      width: 132px;
    }

    .heroBanner__title {
      font-size: clamp(30px, 7vw, 48px);
      letter-spacing: -1px;
    }

    .heroBanner__subtitle {
      font-size: clamp(16px, 2.4vw, 19px);
    }

    .heroBanner__card--photo {
      min-height: 360px;
    }
  }

  @media (max-width: 560px) {
    .heroBanner__card {
      padding-top: 6px;
      padding-bottom: 6px;
      gap: 20px;
    }

    .heroBanner__copy {
      grid-template-columns: 52px minmax(0, 1fr);
      column-gap: 14px;
    }

    .heroBanner__icon {
      width: 52px;
      height: 52px;
      margin-top: 2px;
    }

    .heroBanner__title {
      font-size: 29px;
      line-height: 1.01;
      white-space: normal;
    }

    .heroBanner__subtitle {
      margin-top: 10px;
      max-width: 22ch;
      font-size: 15px;
      line-height: 1.34;
    }

    .heroBanner__logo {
      width: 110px;
    }

    .heroBanner__stack {
      padding-left: 14px;
      padding-right: 14px;
      gap: 5px;
    }

    .heroBanner__row {
      gap: 5px;
    }

    .heroBanner__cube {
      width: 44px;
      height: 44px;
      flex-basis: 44px;
      border-radius: 13px;
    }

    .heroBanner__cube img {
      width: 60%;
      height: 60%;
    }

    .heroBanner__photoOverlay {
      left: 16px;
      right: 16px;
      bottom: 16px;
    }

    .heroBanner__appBtn {
      min-height: 42px;
      padding: 0 15px;
      font-size: 13.5px;
    }
  }
</style>
