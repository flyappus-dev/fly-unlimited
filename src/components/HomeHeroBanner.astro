---
const componentId = `home-hero-${Math.random().toString(36).slice(2, 10)}`;

const slides = [
  {
    type: "message",
    eyebrow: "FLY Unlimited",
    title: "It’s Time to FLY",
    subtitle: "Clean collaboration, beautiful presentation, and a homepage hero that feels premium.",
  },
  {
    type: "image",
    src: "/home-banner-photo-1.jpg",
    alt: "Home banner photo 1",
  },
  {
    type: "image",
    src: "/home-banner-photo-2.jpg",
    alt: "Home banner photo 2",
  },
];
---

<section class="homeHeroBanner" id={componentId} aria-label="Home hero banner">
  <div class="heroShell">
    <div class="heroViewport" data-viewport>
      {slides.map((slide, index) => (
        <article
          class={`heroSlide ${index === 0 ? "is-active" : ""}`}
          data-slide
          aria-hidden={index === 0 ? "false" : "true"}
        >
          {slide.type === "message" ? (
            <div class="messageSlide">
              <div class="messageOverlay"></div>

              <div class="messageContent">
                <div class="eyebrowPill">
                  <span class="eyebrowDot"></span>
                  <span>{slide.eyebrow}</span>
                </div>

                <h1>{slide.title}</h1>
                <p>{slide.subtitle}</p>
              </div>
            </div>
          ) : (
            <div class="imageSlide">
              <img src={slide.src} alt={slide.alt} loading="eager" decoding="async" />
              <div class="imageShade"></div>

              <div class="imageBadge">
                <span class="eyebrowDot"></span>
                <span>FLY Unlimited</span>
              </div>
            </div>
          )}
        </article>
      ))}
    </div>

    <div class="heroDots" aria-label="Hero banner navigation">
      {slides.map((_, index) => (
        <button
          type="button"
          class={`heroDot ${index === 0 ? "is-active" : ""}`}
          data-dot
          aria-label={`Go to banner ${index + 1}`}
          aria-pressed={index === 0 ? "true" : "false"}
        />
      ))}
    </div>
  </div>
</section>

<script is:inline define:vars={{ componentId }}>
  (() => {
    const root = document.getElementById(componentId);
    if (!root) return;

    const slides = Array.from(root.querySelectorAll("[data-slide]"));
    const dots = Array.from(root.querySelectorAll("[data-dot]"));

    if (!slides.length || slides.length !== dots.length) return;

    let current = 0;
    let timer = null;
    const intervalMs = 7800;

    const showSlide = (nextIndex) => {
      current = nextIndex;

      slides.forEach((slide, index) => {
        const active = index === current;
        slide.classList.toggle("is-active", active);
        slide.setAttribute("aria-hidden", active ? "false" : "true");
      });

      dots.forEach((dot, index) => {
        const active = index === current;
        dot.classList.toggle("is-active", active);
        dot.setAttribute("aria-pressed", active ? "true" : "false");
      });
    };

    const start = () => {
      stop();
      timer = window.setInterval(() => {
        showSlide((current + 1) % slides.length);
      }, intervalMs);
    };

    const stop = () => {
      if (timer) {
        window.clearInterval(timer);
        timer = null;
      }
    };

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        showSlide(index);
        start();
      });
    });

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);

    showSlide(0);
    start();
  })();
</script>

<style>
  .homeHeroBanner {
    width: 100%;
  }

  .heroShell {
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
  }

  .heroViewport {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 360px;
    border-radius: 30px;
    overflow: hidden;
    background: #f3f3f3;
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.08),
      0 2px 10px rgba(0, 0, 0, 0.04);
  }

  .heroSlide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: scale(1.01);
    transition:
      opacity 0.55s ease,
      transform 0.75s ease,
      visibility 0.55s ease;
  }

  .heroSlide.is-active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: scale(1);
  }

  .messageSlide,
  .imageSlide {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .messageSlide {
    background:
      radial-gradient(circle at 20% 20%, rgba(108, 43, 217, 0.18), transparent 28%),
      radial-gradient(circle at 85% 25%, rgba(0, 0, 0, 0.08), transparent 24%),
      linear-gradient(180deg, #ffffff 0%, #f6f6f8 100%);
  }

  .messageOverlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.3), transparent 45%),
      linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.02));
    pointer-events: none;
  }

  .messageContent {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    padding: clamp(24px, 4vw, 42px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    text-align: left;
  }

  .eyebrowPill,
  .imageBadge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(0, 0, 0, 0.08);
    color: rgba(11, 12, 16, 0.82);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.2px;
    backdrop-filter: blur(10px);
  }

  .eyebrowDot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: #6c2bd9;
    flex: 0 0 auto;
  }

  .messageContent h1 {
    margin: 18px 0 10px;
    max-width: 8.5ch;
    font-size: clamp(40px, 7vw, 78px);
    line-height: 0.95;
    letter-spacing: -0.05em;
    font-weight: 800;
    color: #0b0c10;
  }

  .messageContent p {
    margin: 0;
    max-width: 38rem;
    font-size: clamp(14px, 2vw, 18px);
    line-height: 1.45;
    color: rgba(11, 12, 16, 0.64);
  }

  .imageSlide img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .imageShade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0.2)),
      linear-gradient(0deg, rgba(0, 0, 0, 0.34), rgba(0, 0, 0, 0.02) 45%);
    pointer-events: none;
  }

  .imageBadge {
    position: absolute;
    left: clamp(18px, 3vw, 26px);
    bottom: clamp(18px, 3vw, 26px);
    z-index: 1;
  }

  .heroDots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    padding-top: 16px;
  }

  .heroDot {
    width: 9px;
    height: 9px;
    border: 0;
    border-radius: 999px;
    background: rgba(11, 12, 16, 0.18);
    padding: 0;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      width 0.2s ease;
  }

  .heroDot.is-active {
    width: 24px;
    background: #0b0c10;
  }

  .heroDot:hover {
    transform: scale(1.08);
  }

  @media (max-width: 720px) {
    .heroViewport {
      aspect-ratio: 4 / 5;
      min-height: 420px;
      border-radius: 24px;
    }

    .messageContent {
      justify-content: flex-end;
      padding: 22px;
    }

    .messageContent h1 {
      max-width: 10ch;
    }

    .heroDots {
      padding-top: 14px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .heroSlide,
    .heroDot {
      transition: none;
    }
  }
</style>
