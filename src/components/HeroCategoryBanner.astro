---
import { categoryMeta } from "../data/categoryMeta";
import { bannerVariants } from "../data/bannerVariants";

const initialVariant = bannerVariants[0];
const initialHasLogo = Boolean(initialVariant.logoAsset);
---

<div class="heroBanner" id="heroCategoryBanner">
  <div
    class="heroBanner__card"
    data-stack-style={initialVariant.stackStyle}
    data-has-logo={initialHasLogo ? "true" : "false"}
  >
    <div class="heroBanner__copy">
      <div class="heroBanner__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M12 2.8l1.7 5.8 5.5 1.7-5.5 1.7-1.7 5.8-1.7-5.8-5.5-1.7 5.5-1.7L12 2.8z"></path>
        </svg>
      </div>

      <div class="heroBanner__text">
        <div class="heroBanner__headlineRow">
          <h1 class="heroBanner__title" data-banner-title>{initialVariant.title}</h1>

          <div
            class:list={[
              "heroBanner__logoWrap",
              !initialHasLogo && "is-hidden",
            ]}
            data-banner-logo-wrap
          >
            {initialVariant.logoAsset && (
              <img
                class="heroBanner__logo"
                data-banner-logo
                src={initialVariant.logoAsset}
                alt={initialVariant.logoAlt ?? "FLY logo"}
                loading="eager"
                decoding="async"
              />
            )}
          </div>
        </div>

        <p
          class:list={[
            "heroBanner__subtitle",
            !initialVariant.subtitle && "is-hidden",
          ]}
          data-banner-subtitle
        >
          {initialVariant.subtitle}
        </p>
      </div>
    </div>

    <div class="heroBanner__stack" data-banner-stack aria-hidden="true">
      {initialVariant.rows.map((row, rowIndex) => (
        <div class="heroBanner__row">
          {row.map((key, colIndex) => (
            <div
              class="heroBanner__cube"
              style={`--cube-color:${categoryMeta[key].color}; --delay:${rowIndex * 110 + colIndex * 46}ms;`}
            >
              <img src={categoryMeta[key].icon} alt="" loading="eager" decoding="async" />
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</div>

<script
  type="application/json"
  id="hero-banner-data"
  set:html={JSON.stringify({ variants: bannerVariants, meta: categoryMeta })}
/>

<script is:inline>
  (() => {
    const root = document.getElementById("heroCategoryBanner");
    const dataEl = document.getElementById("hero-banner-data");
    if (!root || !dataEl) return;

    const payload = JSON.parse(dataEl.textContent || "{}");
    const variants = payload.variants || [];
    const meta = payload.meta || {};

    const cardEl = root.querySelector(".heroBanner__card");
    const titleEl = root.querySelector("[data-banner-title]");
    const subtitleEl = root.querySelector("[data-banner-subtitle]");
    const logoWrapEl = root.querySelector("[data-banner-logo-wrap]");
    const stackEl = root.querySelector("[data-banner-stack]");

    if (!cardEl || !titleEl || !subtitleEl || !logoWrapEl || !stackEl || !variants.length) return;

    let index = Math.floor(Math.random() * variants.length);

    function cubeMarkup(key, delay) {
      const item = meta[key];
      if (!item) return "";
      return `
        <div class="heroBanner__cube" style="--cube-color:${item.color}; --delay:${delay}ms;">
          <img src="${item.icon}" alt="" loading="eager" decoding="async" />
        </div>
      `;
    }

    function rowsMarkup(rows) {
      return rows
        .map((row, rowIndex) => {
          const cubes = row
            .map((key, colIndex) => cubeMarkup(key, rowIndex * 110 + colIndex * 46))
            .join("");
          return `<div class="heroBanner__row">${cubes}</div>`;
        })
        .join("");
    }

    function renderLogo(variant) {
      const hasLogo = Boolean(variant.logoAsset);
      cardEl.setAttribute("data-has-logo", hasLogo ? "true" : "false");

      if (!hasLogo) {
        logoWrapEl.classList.add("is-hidden");
        logoWrapEl.innerHTML = "";
        return;
      }

      logoWrapEl.classList.remove("is-hidden");
      logoWrapEl.innerHTML = `
        <img
          class="heroBanner__logo"
          src="${variant.logoAsset}"
          alt="${variant.logoAlt || "FLY logo"}"
          loading="eager"
          decoding="async"
        />
      `;
    }

    function render(nextIndex) {
      const variant = variants[nextIndex];
      if (!variant) return;

      cardEl.setAttribute("data-stack-style", variant.stackStyle || "playfulRows");

      titleEl.textContent = variant.title || "";

      if (variant.subtitle && variant.subtitle.trim()) {
        subtitleEl.textContent = variant.subtitle;
        subtitleEl.classList.remove("is-hidden");
      } else {
        subtitleEl.textContent = "";
        subtitleEl.classList.add("is-hidden");
      }

      renderLogo(variant);
      stackEl.innerHTML = rowsMarkup(variant.rows || []);
    }

    render(index);

    if (variants.length > 1) {
      window.setInterval(() => {
        index = (index + 1) % variants.length;
        render(index);
      }, 7800);
    }
  })();
</script>

<style is:global>
  .heroBanner {
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
    background: #fff;
  }

  .heroBanner__card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(20px, 3vw, 38px);
    min-height: clamp(248px, 30vw, 352px);
    padding: clamp(8px, 1.2vw, 14px) clamp(16px, 2.6vw, 30px);
    background: #fff;
  }

  .heroBanner__copy {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    column-gap: 18px;
    min-width: 0;
    align-self: center;
  }

  .heroBanner__icon {
    width: 56px;
    height: 56px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.045);
    border: 1px solid rgba(0, 0, 0, 0.05);
    margin-top: 4px;
    flex: 0 0 auto;
  }

  .heroBanner__icon svg {
    width: 18px;
    height: 18px;
    fill: rgba(11, 12, 16, 0.82);
  }

  .heroBanner__text {
    min-width: 0;
    max-width: 36rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .heroBanner__headlineRow {
    width: 100%;
    display: block;
  }

  .heroBanner__title {
    margin: 0;
    font-size: clamp(34px, 4.8vw, 70px);
    line-height: 0.96;
    letter-spacing: -1.5px;
    text-wrap: balance;
  }

  .heroBanner__subtitle {
    margin: 10px 0 0;
    max-width: 24ch;
    color: rgba(11, 12, 16, 0.66);
    font-size: clamp(17px, 1.75vw, 22px);
    line-height: 1.25;
    text-wrap: pretty;
  }

  .heroBanner__subtitle.is-hidden {
    display: none;
  }

  .heroBanner__logoWrap {
    margin-top: 14px;
    display: flex;
    align-items: center;
  }

  .heroBanner__logoWrap.is-hidden {
    display: none;
  }

  .heroBanner__logo {
    width: clamp(118px, 10vw, 164px);
    height: auto;
    display: block;
    object-fit: contain;
  }

  .heroBanner__stack {
    align-self: center;
    width: fit-content;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 2px 8px;
  }

  .heroBanner__row {
    display: flex;
    gap: 6px;
  }

  .heroBanner__cube {
    width: 60px;
    height: 60px;
    border-radius: 18px;
    background: var(--cube-color);
    display: grid;
    place-items: center;
    flex: 0 0 60px;
    animation: heroBannerDrop 700ms cubic-bezier(0.2, 0.82, 0.2, 1) both;
    animation-delay: var(--delay, 0ms);
    will-change: transform, opacity;
  }

  .heroBanner__cube img {
    width: 58%;
    height: 58%;
    display: block;
    pointer-events: none;
    user-select: none;
  }

  /* Full block / logo variant */
  .heroBanner__card[data-stack-style="fullBlock"] {
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(18px, 2.4vw, 28px);
  }

  .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__copy {
    align-self: center;
  }

  .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__text {
    max-width: 42rem;
  }

  .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__headlineRow {
    display: block;
    max-width: 34rem;
  }

  .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__headlineRow {
    display: flex;
    align-items: flex-end;
    gap: 18px;
    flex-wrap: nowrap;
    max-width: 40rem;
    overflow: visible;
  }

  .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__title {
    max-width: 7.6ch;
    flex: 0 1 auto;
    text-wrap: balance;
  }

  .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__logoWrap {
    margin: 0 0 0.5rem;
    flex: 0 0 auto;
    align-self: flex-end;
  }

  .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__logo {
    width: clamp(132px, 11vw, 176px);
  }

  .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__stack {
    justify-self: end;
    align-items: flex-start;
    max-width: 332px;
  }

  .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__row {
    justify-content: flex-start;
  }

  /* Playful rows */
  .heroBanner__card[data-stack-style="playfulRows"] {
    grid-template-columns: minmax(0, 0.96fr) auto;
    gap: clamp(18px, 2.8vw, 32px);
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__copy {
    justify-self: center;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__text {
    align-items: center;
    text-align: center;
    max-width: 30rem;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__subtitle {
    max-width: 23ch;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__stack {
    justify-self: end;
    align-items: center;
    max-width: 300px;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__row {
    justify-content: center;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__row:last-child {
    transform: translateX(-3px);
  }

  /* Left rise */
  .heroBanner__card[data-stack-style="leftRise"] {
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(16px, 2.4vw, 26px);
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__stack {
    order: 1;
    justify-self: start;
    align-items: flex-start;
    max-width: 336px;
    padding-left: 0;
    padding-right: 0;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__row {
    justify-content: flex-start;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__copy {
    order: 2;
    justify-self: start;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__text {
    max-width: 28rem;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__title {
    max-width: 9.2ch;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__subtitle {
    max-width: 21ch;
  }

  @keyframes heroBannerDrop {
    0% {
      opacity: 0;
      transform: translate3d(0, -18px, 0) rotate(-5deg);
    }
    55% {
      opacity: 1;
      transform: translate3d(0, 4px, 0) rotate(2deg);
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) rotate(0deg);
    }
  }

  @media (max-width: 980px) {
    .heroBanner__card {
      gap: clamp(16px, 2.8vw, 26px);
      padding-left: clamp(14px, 3vw, 22px);
      padding-right: clamp(14px, 3vw, 22px);
      min-height: clamp(236px, 28vw, 320px);
    }

    .heroBanner__cube {
      width: 56px;
      height: 56px;
      flex-basis: 56px;
      border-radius: 17px;
    }

    .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__headlineRow {
      max-width: 36rem;
      gap: 14px;
    }

    .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__title {
      max-width: 7.1ch;
    }

    .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__stack {
      max-width: 304px;
    }

    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__stack {
      max-width: 276px;
    }

    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__stack {
      max-width: 300px;
    }
  }

  @media (max-width: 860px) {
    .heroBanner__card,
    .heroBanner__card[data-stack-style="fullBlock"],
    .heroBanner__card[data-stack-style="playfulRows"],
    .heroBanner__card[data-stack-style="leftRise"] {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 24px;
      min-height: auto;
      padding-left: clamp(14px, 5vw, 24px);
      padding-right: clamp(14px, 5vw, 24px);
    }

    .heroBanner__copy,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__copy {
      order: 1;
      width: 100%;
      justify-self: stretch;
    }

    .heroBanner__text,
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__text,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__text {
      max-width: 100%;
      align-items: flex-start;
      text-align: left;
    }

    .heroBanner__subtitle,
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__subtitle,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__subtitle {
      max-width: 25ch;
    }

    .heroBanner__stack,
    .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__stack,
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__stack,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__stack {
      order: 2;
      width: 100%;
      max-width: 100%;
      align-items: center;
      justify-self: center;
      padding-left: 12px;
      padding-right: 12px;
    }

    .heroBanner__row,
    .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__row,
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__row,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__row {
      justify-content: center;
      width: 100%;
      flex-wrap: wrap;
      transform: none;
    }

    .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__headlineRow {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      max-width: 100%;
    }

    .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__title,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__title {
      max-width: 100%;
    }

    .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__logoWrap {
      margin: 0;
    }

    .heroBanner__card[data-stack-style="fullBlock"][data-has-logo="true"] .heroBanner__logo {
      width: 132px;
    }

    .heroBanner__title {
      font-size: clamp(30px, 7vw, 48px);
      letter-spacing: -1px;
    }

    .heroBanner__subtitle {
      font-size: clamp(16px, 2.4vw, 19px);
    }
  }

  @media (max-width: 560px) {
    .heroBanner__card {
      padding-top: 6px;
      padding-bottom: 6px;
      gap: 20px;
    }

    .heroBanner__copy {
      grid-template-columns: 52px minmax(0, 1fr);
      column-gap: 14px;
    }

    .heroBanner__icon {
      width: 52px;
      height: 52px;
      margin-top: 2px;
    }

    .heroBanner__title {
      font-size: 29px;
      line-height: 1.01;
      white-space: normal;
    }

    .heroBanner__subtitle {
      margin-top: 10px;
      max-width: 22ch;
      font-size: 15px;
      line-height: 1.34;
    }

    .heroBanner__logo {
      width: 110px;
    }

    .heroBanner__stack {
      padding-left: 14px;
      padding-right: 14px;
      gap: 5px;
    }

    .heroBanner__row {
      gap: 5px;
    }

    .heroBanner__cube {
      width: 44px;
      height: 44px;
      flex-basis: 44px;
      border-radius: 13px;
    }

    .heroBanner__cube img {
      width: 60%;
      height: 60%;
    }
  }
</style>
