---
import { categoryMeta } from "../data/categoryMeta";
import { bannerVariants } from "../data/bannerVariants";

const initialVariant = bannerVariants[0];
---

<div class="heroBanner" id="heroCategoryBanner">
  <div class="heroBanner__card">
    <div class="heroBanner__copy">
      <div class="heroBanner__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M12 2.8l1.7 5.8 5.5 1.7-5.5 1.7-1.7 5.8-1.7-5.8-5.5-1.7 5.5-1.7L12 2.8z"></path>
        </svg>
      </div>

      <div class="heroBanner__text">
        <h1 class="heroBanner__title" data-banner-title>{initialVariant.title}</h1>
        <p class="heroBanner__subtitle" data-banner-subtitle>{initialVariant.subtitle}</p>
      </div>
    </div>

    <div class="heroBanner__stack" data-banner-stack aria-hidden="true">
      {initialVariant.rows.map((row, rowIndex) => (
        <div class="heroBanner__row">
          {row.map((key, colIndex) => (
            <div
              class="heroBanner__cube"
              style={`--cube-color:${categoryMeta[key].color}; --delay:${rowIndex * 95 + colIndex * 40}ms;`}
            >
              <img src={categoryMeta[key].icon} alt="" loading="eager" decoding="async" />
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</div>

<script
  type="application/json"
  id="hero-banner-data"
  set:html={JSON.stringify({ variants: bannerVariants, meta: categoryMeta })}
/>

<script is:inline>
  (() => {
    const root = document.getElementById("heroCategoryBanner");
    const dataEl = document.getElementById("hero-banner-data");
    if (!root || !dataEl) return;

    const payload = JSON.parse(dataEl.textContent || "{}");
    const variants = payload.variants || [];
    const meta = payload.meta || {};

    const titleEl = root.querySelector("[data-banner-title]");
    const subtitleEl = root.querySelector("[data-banner-subtitle]");
    const stackEl = root.querySelector("[data-banner-stack]");

    if (!titleEl || !subtitleEl || !stackEl || !variants.length) return;

    let index = Math.floor(Math.random() * variants.length);

    function cubeMarkup(key, delay) {
      const item = meta[key];
      if (!item) return "";
      return `
        <div class="heroBanner__cube" style="--cube-color:${item.color}; --delay:${delay}ms;">
          <img src="${item.icon}" alt="" loading="eager" decoding="async" />
        </div>
      `;
    }

    function rowsMarkup(rows) {
      return rows
        .map((row, rowIndex) => {
          const cubes = row
            .map((key, colIndex) => cubeMarkup(key, rowIndex * 95 + colIndex * 40))
            .join("");
          return `<div class="heroBanner__row">${cubes}</div>`;
        })
        .join("");
    }

    function render(nextIndex) {
      const variant = variants[nextIndex];
      if (!variant) return;

      titleEl.textContent = variant.title;
      subtitleEl.textContent = variant.subtitle;
      stackEl.innerHTML = rowsMarkup(variant.rows);
    }

    render(index);

    if (variants.length > 1) {
      window.setInterval(() => {
        index = (index + 1) % variants.length;
        render(index);
      }, 6800);
    }
  })();
</script>

<style is:global>
  .heroBanner {
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
    background: #fff;
  }

  .heroBanner__card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: clamp(28px, 5vw, 60px);
    min-height: clamp(260px, 34vw, 368px);
    padding: clamp(8px, 1vw, 12px) 0;
    background: #fff;
  }

  .heroBanner__copy {
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr);
    column-gap: 18px;
    align-self: start;
    min-width: 0;
  }

  .heroBanner__icon {
    width: 54px;
    height: 54px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.045);
    border: 1px solid rgba(0, 0, 0, 0.05);
    margin-top: 4px;
  }

  .heroBanner__icon svg {
    width: 18px;
    height: 18px;
    fill: rgba(11, 12, 16, 0.82);
  }

  .heroBanner__text {
    min-width: 0;
    max-width: 34rem;
  }

  .heroBanner__title {
    margin: 0;
    font-size: clamp(34px, 4.8vw, 72px);
    line-height: 0.98;
    letter-spacing: -1.5px;
    text-wrap: balance;
  }

  .heroBanner__subtitle {
    margin: 14px 0 0;
    max-width: 26ch;
    color: rgba(11, 12, 16, 0.66);
    font-size: clamp(17px, 1.8vw, 22px);
    line-height: 1.3;
    text-wrap: pretty;
  }

  .heroBanner__stack {
    align-self: end;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    padding-right: 2px;
    padding-bottom: 4px;
  }

  .heroBanner__row {
    display: flex;
    justify-content: flex-end;
    gap: 5px;
  }

  .heroBanner__cube {
    width: 59px;
    height: 59px;
    border-radius: 17px;
    background: var(--cube-color);
    display: grid;
    place-items: center;
    flex: 0 0 59px;
    animation: heroBannerDrop 640ms cubic-bezier(0.2, 0.82, 0.2, 1) both;
    animation-delay: var(--delay, 0ms);
    will-change: transform, opacity;
  }

  .heroBanner__cube img {
    width: 50.5%;
    height: 50.5%;
    display: block;
    pointer-events: none;
    user-select: none;
  }

  @keyframes heroBannerDrop {
    0% {
      opacity: 0;
      transform: translate3d(0, -16px, 0) rotate(-4deg);
    }
    55% {
      opacity: 1;
      transform: translate3d(0, 3px, 0) rotate(2deg);
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) rotate(0deg);
    }
  }

  @media (max-width: 860px) {
    .heroBanner__card {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 28px;
      min-height: auto;
    }

    .heroBanner__copy {
      width: 100%;
    }

    .heroBanner__text {
      max-width: 100%;
    }

    .heroBanner__stack {
      width: 100%;
      align-items: flex-end;
    }

    .heroBanner__title {
      font-size: clamp(30px, 7vw, 48px);
      letter-spacing: -1px;
    }

    .heroBanner__subtitle {
      max-width: 28ch;
      font-size: clamp(16px, 2.4vw, 19px);
    }
  }

  @media (max-width: 560px) {
    .heroBanner__card {
      padding: 6px 0;
      gap: 22px;
    }

    .heroBanner__copy {
      grid-template-columns: 52px minmax(0, 1fr);
      column-gap: 14px;
    }

    .heroBanner__icon {
      width: 52px;
      height: 52px;
      margin-top: 2px;
    }

    .heroBanner__title {
      font-size: 29px;
      line-height: 1.01;
      white-space: normal;
    }

    .heroBanner__subtitle {
      margin-top: 10px;
      max-width: 22ch;
      font-size: 15px;
      line-height: 1.34;
    }

    .heroBanner__cube {
      width: 42px;
      height: 42px;
      flex-basis: 42px;
      border-radius: 13px;
    }

    .heroBanner__cube img {
      width: 50.5%;
      height: 50.5%;
    }

    .heroBanner__row {
      gap: 4px;
    }

    .heroBanner__stack {
      gap: 4px;
      padding-right: 0;
      padding-bottom: 0;
    }
  }
</style>
