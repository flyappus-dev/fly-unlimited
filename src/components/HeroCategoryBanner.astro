---
import { categoryMeta } from "../data/categoryMeta";
import { bannerVariants } from "../data/bannerVariants";

const initialVariant = bannerVariants[0];
const initialHasLogo = Boolean(initialVariant.logoAsset);
---

<div class="heroBanner" id="heroCategoryBanner">
  <div class="heroBanner__card" data-stack-style={initialVariant.stackStyle}>
    <div class="heroBanner__copy">
      <div class="heroBanner__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M12 2.8l1.7 5.8 5.5 1.7-5.5 1.7-1.7 5.8-1.7-5.8-5.5-1.7 5.5-1.7L12 2.8z"></path>
        </svg>
      </div>

      <div class="heroBanner__text">
        <h1 class="heroBanner__title" data-banner-title>{initialVariant.title}</h1>
        <p
          class:list={[
            "heroBanner__subtitle",
            !initialVariant.subtitle && "is-hidden",
          ]}
          data-banner-subtitle
        >
          {initialVariant.subtitle}
        </p>

        <div
          class:list={[
            "heroBanner__logoWrap",
            !initialHasLogo && "is-hidden",
          ]}
          data-banner-logo-wrap
        >
          {initialVariant.logoAsset && (
            <img
              class="heroBanner__logo"
              data-banner-logo
              src={initialVariant.logoAsset}
              alt={initialVariant.logoAlt ?? "FLY logo"}
              loading="eager"
              decoding="async"
            />
          )}
        </div>
      </div>
    </div>

    <div class="heroBanner__stack" data-banner-stack aria-hidden="true">
      {initialVariant.rows.map((row, rowIndex) => (
        <div class="heroBanner__row">
          {row.map((key, colIndex) => (
            <div
              class="heroBanner__cube"
              style={`--cube-color:${categoryMeta[key].color}; --delay:${rowIndex * 110 + colIndex * 46}ms;`}
            >
              <img src={categoryMeta[key].icon} alt="" loading="eager" decoding="async" />
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</div>

<script
  type="application/json"
  id="hero-banner-data"
  set:html={JSON.stringify({ variants: bannerVariants, meta: categoryMeta })}
/>

<script is:inline>
  (() => {
    const root = document.getElementById("heroCategoryBanner");
    const dataEl = document.getElementById("hero-banner-data");
    if (!root || !dataEl) return;

    const payload = JSON.parse(dataEl.textContent || "{}");
    const variants = payload.variants || [];
    const meta = payload.meta || {};

    const cardEl = root.querySelector(".heroBanner__card");
    const titleEl = root.querySelector("[data-banner-title]");
    const subtitleEl = root.querySelector("[data-banner-subtitle]");
    const logoWrapEl = root.querySelector("[data-banner-logo-wrap]");
    const stackEl = root.querySelector("[data-banner-stack]");

    if (!cardEl || !titleEl || !subtitleEl || !logoWrapEl || !stackEl || !variants.length) return;

    let index = Math.floor(Math.random() * variants.length);

    function cubeMarkup(key, delay) {
      const item = meta[key];
      if (!item) return "";
      return `
        <div class="heroBanner__cube" style="--cube-color:${item.color}; --delay:${delay}ms;">
          <img src="${item.icon}" alt="" loading="eager" decoding="async" />
        </div>
      `;
    }

    function rowsMarkup(rows) {
      return rows
        .map((row, rowIndex) => {
          const cubes = row
            .map((key, colIndex) => cubeMarkup(key, rowIndex * 110 + colIndex * 46))
            .join("");
          return `<div class="heroBanner__row">${cubes}</div>`;
        })
        .join("");
    }

    function renderLogo(variant) {
      const hasLogo = Boolean(variant.logoAsset);

      if (!hasLogo) {
        logoWrapEl.classList.add("is-hidden");
        logoWrapEl.innerHTML = "";
        return;
      }

      logoWrapEl.classList.remove("is-hidden");
      logoWrapEl.innerHTML = `
        <img
          class="heroBanner__logo"
          src="${variant.logoAsset}"
          alt="${variant.logoAlt || "FLY logo"}"
          loading="eager"
          decoding="async"
        />
      `;
    }

    function render(nextIndex) {
      const variant = variants[nextIndex];
      if (!variant) return;

      cardEl.setAttribute("data-stack-style", variant.stackStyle || "playfulRows");

      titleEl.textContent = variant.title || "";

      if (variant.subtitle && variant.subtitle.trim()) {
        subtitleEl.textContent = variant.subtitle;
        subtitleEl.classList.remove("is-hidden");
      } else {
        subtitleEl.textContent = "";
        subtitleEl.classList.add("is-hidden");
      }

      renderLogo(variant);
      stackEl.innerHTML = rowsMarkup(variant.rows || []);
    }

    render(index);

    if (variants.length > 1) {
      window.setInterval(() => {
        index = (index + 1) % variants.length;
        render(index);
      }, 7600);
    }
  })();
</script>

<style is:global>
  .heroBanner {
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
    background: #fff;
  }

  .heroBanner__card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(24px, 4.8vw, 68px);
    min-height: clamp(280px, 36vw, 410px);
    padding: clamp(10px, 1.2vw, 16px) clamp(10px, 2.4vw, 28px);
    background: #fff;
  }

  .heroBanner__copy {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    column-gap: 18px;
    align-self: start;
    min-width: 0;
  }

  .heroBanner__icon {
    width: 56px;
    height: 56px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.045);
    border: 1px solid rgba(0, 0, 0, 0.05);
    margin-top: 4px;
    flex: 0 0 auto;
  }

  .heroBanner__icon svg {
    width: 18px;
    height: 18px;
    fill: rgba(11, 12, 16, 0.82);
  }

  .heroBanner__text {
    min-width: 0;
    max-width: 38rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .heroBanner__title {
    margin: 0;
    font-size: clamp(34px, 4.9vw, 72px);
    line-height: 0.98;
    letter-spacing: -1.5px;
    text-wrap: balance;
  }

  .heroBanner__subtitle {
    margin: 12px 0 0;
    max-width: 28ch;
    color: rgba(11, 12, 16, 0.66);
    font-size: clamp(17px, 1.8vw, 22px);
    line-height: 1.26;
    text-wrap: pretty;
  }

  .heroBanner__subtitle.is-hidden {
    display: none;
  }

  .heroBanner__logoWrap {
    margin-top: 18px;
    display: flex;
    align-items: center;
  }

  .heroBanner__logoWrap.is-hidden {
    display: none;
  }

  .heroBanner__logo {
    width: clamp(90px, 9vw, 138px);
    height: auto;
    display: block;
    object-fit: contain;
  }

  .heroBanner__stack {
    align-self: center;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: min(100%, 430px);
    padding: 4px 14px 6px 14px;
  }

  .heroBanner__row {
    display: flex;
    gap: 6px;
  }

  .heroBanner__cube {
    width: 62px;
    height: 62px;
    border-radius: 18px;
    background: var(--cube-color);
    display: grid;
    place-items: center;
    flex: 0 0 62px;
    animation: heroBannerDrop 700ms cubic-bezier(0.2, 0.82, 0.2, 1) both;
    animation-delay: var(--delay, 0ms);
    will-change: transform, opacity;
  }

  .heroBanner__cube img {
    width: 56%;
    height: 56%;
    display: block;
    pointer-events: none;
    user-select: none;
  }

  .heroBanner__card[data-stack-style="fullBlock"] {
    grid-template-columns: minmax(0, 0.9fr) auto;
    align-items: center;
  }

  .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__stack {
    align-items: flex-start;
    justify-self: end;
  }

  .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__row {
    justify-content: flex-start;
  }

  .heroBanner__card[data-stack-style="playfulRows"] {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__copy {
    justify-self: center;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__text {
    align-items: center;
    text-align: center;
    max-width: 31rem;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__subtitle {
    max-width: 24ch;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__stack {
    align-items: center;
    justify-self: end;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__row {
    justify-content: center;
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__row:nth-child(odd) {
    transform: translateX(-10px);
  }

  .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__row:nth-child(even) {
    transform: translateX(8px);
  }

  .heroBanner__card[data-stack-style="leftRise"] {
    grid-template-columns: auto minmax(0, 1fr);
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__copy {
    order: 2;
    justify-self: end;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__text {
    max-width: 34rem;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__stack {
    order: 1;
    align-items: flex-start;
    justify-self: start;
    padding-left: 18px;
    padding-right: 6px;
  }

  .heroBanner__card[data-stack-style="leftRise"] .heroBanner__row {
    justify-content: flex-start;
  }

  @keyframes heroBannerDrop {
    0% {
      opacity: 0;
      transform: translate3d(0, -18px, 0) rotate(-5deg);
    }
    55% {
      opacity: 1;
      transform: translate3d(0, 4px, 0) rotate(2deg);
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) rotate(0deg);
    }
  }

  @media (max-width: 980px) {
    .heroBanner__card {
      gap: clamp(20px, 4vw, 36px);
      padding-left: clamp(14px, 3vw, 24px);
      padding-right: clamp(14px, 3vw, 24px);
    }

    .heroBanner__stack {
      max-width: min(100%, 360px);
      padding-left: 10px;
      padding-right: 10px;
    }

    .heroBanner__cube {
      width: 58px;
      height: 58px;
      flex-basis: 58px;
      border-radius: 17px;
    }
  }

  @media (max-width: 860px) {
    .heroBanner__card,
    .heroBanner__card[data-stack-style="fullBlock"],
    .heroBanner__card[data-stack-style="playfulRows"],
    .heroBanner__card[data-stack-style="leftRise"] {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 26px;
      min-height: auto;
      padding-left: clamp(14px, 5vw, 24px);
      padding-right: clamp(14px, 5vw, 24px);
    }

    .heroBanner__copy,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__copy {
      order: 1;
      width: 100%;
      justify-self: stretch;
    }

    .heroBanner__text,
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__text,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__text {
      max-width: 100%;
      align-items: flex-start;
      text-align: left;
    }

    .heroBanner__subtitle,
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__subtitle {
      max-width: 26ch;
    }

    .heroBanner__stack,
    .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__stack,
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__stack,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__stack {
      order: 2;
      width: 100%;
      max-width: 100%;
      align-items: center;
      justify-self: center;
      padding-left: 12px;
      padding-right: 12px;
    }

    .heroBanner__row,
    .heroBanner__card[data-stack-style="fullBlock"] .heroBanner__row,
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__row,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__row {
      justify-content: center;
      width: 100%;
      flex-wrap: wrap;
    }

    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__row:nth-child(odd),
    .heroBanner__card[data-stack-style="playfulRows"] .heroBanner__row:nth-child(even) {
      transform: none;
    }

    .heroBanner__title {
      font-size: clamp(30px, 7vw, 48px);
      letter-spacing: -1px;
    }

    .heroBanner__subtitle {
      font-size: clamp(16px, 2.4vw, 19px);
    }
  }

  @media (max-width: 560px) {
    .heroBanner__card {
      padding-top: 6px;
      padding-bottom: 6px;
      gap: 22px;
    }

    .heroBanner__copy {
      grid-template-columns: 52px minmax(0, 1fr);
      column-gap: 14px;
    }

    .heroBanner__icon {
      width: 52px;
      height: 52px;
      margin-top: 2px;
    }

    .heroBanner__title {
      font-size: 29px;
      line-height: 1.01;
      white-space: normal;
    }

    .heroBanner__subtitle {
      margin-top: 10px;
      max-width: 22ch;
      font-size: 15px;
      line-height: 1.34;
    }

    .heroBanner__logo {
      width: 96px;
    }

    .heroBanner__stack,
    .heroBanner__card[data-stack-style="leftRise"] .heroBanner__stack {
      padding-left: 18px;
      padding-right: 18px;
      gap: 5px;
    }

    .heroBanner__row {
      gap: 5px;
    }

    .heroBanner__cube {
      width: 44px;
      height: 44px;
      flex-basis: 44px;
      border-radius: 13px;
    }

    .heroBanner__cube img {
      width: 58%;
      height: 58%;
    }
  }
</style>
