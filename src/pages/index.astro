---
import HeroCategoryBanner from "../components/HeroCategoryBanner.astro";

const siteName = "FLY Unlimited";
const contactEmail = "hello@fly-unlimited.com"; // change if needed
const appStoreUrl = "#";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteName}</title>
    <meta name="description" content="It's Time to FLY." />

    <style>
      :root{
        --bg:#ffffff;
        --text:#0b0c10;
        --muted:rgba(11,12,16,.62);

        /* ✅ Keep the purple dot */
        --main:#6C2BD9;

        --max:1120px;

        /* ✅ More breathing room on phones (prevents edge-to-edge text) */
        --pad: clamp(18px, 5vw, 22px);

        --rXL: 28px;
        --ease: cubic-bezier(.2,.8,.2,1);

        /* Approx sticky bar height so hero = “one page” */
        --topbarH: 64px;
      }

      *{ box-sizing:border-box; }
      html,body{ margin:0; padding:0; background: var(--bg); }
      body{
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
        color: var(--text);
        line-height: 1.25;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a{ color:inherit; text-decoration:none; }
      a:focus-visible{
        outline: 3px solid rgba(0,0,0,.18);
        outline-offset: 3px;
        border-radius: 12px;
      }

      /* ===== Top nav: clean white ===== */
      .topbar{
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(255,255,255,.96);
        border-bottom: 1px solid rgba(0,0,0,.06);
      }
      .topbarInner{
        max-width: var(--max);
        margin: 0 auto;
        padding: 10px var(--pad);
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
      }
      .brand{
        display:flex;
        align-items:center;
        gap:10px;
        min-height:44px;
      }
      .mascot{
        width:26px;
        height:26px;
        border-radius:10px;
        object-fit:contain;
        display:block;
      }

      .nav{
        display:flex;
        align-items:center;
        gap: 10px;
      }
      .navBtn{
        width:42px;
        height:42px;
        display:grid;
        place-items:center;
        border-radius: 999px;
        color: rgba(11,12,16,.72);
        transition: background .18s var(--ease), color .18s var(--ease);
      }
      .navBtn:hover{
        background: rgba(0,0,0,.05);
        color: rgba(11,12,16,.92);
      }
      .navBtn.active{
        background: rgba(0,0,0,.08);
        color: rgba(11,12,16,.96);
      }
      .navBtn svg{
        width:18px;
        height:18px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }
      .navIcon{
        width:18px;
        height:18px;
        display:block;
        object-fit:contain;
      }

      /* ===== Layout ===== */
      .wrap{
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 var(--pad);
      }

      /* ===== HERO ===== */
      .hero{
        background: #fff;
        min-height: calc(100svh - var(--topbarH));
        min-height: calc(100vh - var(--topbarH));
        display:flex;
        align-items:center;
        overflow:hidden;
      }

      .heroInner{
        width: 100%;
        padding: 34px 0 42px;
        display:flex;
        flex-direction:column;
        align-items:center;
        text-align:center;
      }

      .heroBannerWrap{
        width: 100%;
        max-width: 980px;
        margin: 0 auto 22px;
      }

      .heroKicker{
        display:inline-flex;
        align-items:center;
        gap:10px;
        padding: 10px 14px;
        border-radius: 999px;
        background: #fff;
        border: 1px solid rgba(0,0,0,.10);
        color: rgba(11,12,16,.78);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: .2px;
      }
      .dot{
        width:9px;
        height:9px;
        border-radius:999px;
        background: var(--main);
      }

      .ctaRow{
        margin-top: 14px;
        display:flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items:center;
        justify-content:center;
      }

      .btn{
        display:inline-flex;
        align-items:center;
        justify-content:center;
        gap:10px;
        height: 44px;
        padding: 0 16px;
        border-radius: 999px;
        border: 1px solid rgba(0,0,0,.12);
        background: #fff;
        color: rgba(11,12,16,.92);
        font-weight: 760;
        font-size: 14px;
        letter-spacing: .1px;
        transition: transform .18s var(--ease), background .18s var(--ease);
      }
      .btn:hover{
        transform: translateY(-1px);
        background: rgba(0,0,0,.02);
      }

      .btnPrimary{
        border-color: transparent;
        background: #0b0c10;
        color: #fff;
      }
      .btnPrimary:hover{ background:#000; }

      .btn svg{
        width:16px;
        height:16px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }

      /* ===== Sections: white, minimal ===== */
      .section{
        padding: 54px 0;
        background:#fff;
      }

      .sectionHeader{
        display:flex;
        align-items:flex-end;
        justify-content:space-between;
        gap: 14px;
        margin-bottom: 16px;
      }
      .sectionTitle{
        margin:0;
        font-size: clamp(22px, 2.2vw, 30px);
        letter-spacing:-.6px;
        line-height:1.08;
      }
      .sectionNote{
        margin:0;
        color: var(--muted);
        font-size: 14.5px;
        line-height:1.35;
        max-width: 60ch;
      }

      .tiles{
        display:flex;
        gap: 16px;
        overflow-x: auto;
        padding-bottom: 6px;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
      }
      .tiles::-webkit-scrollbar{ height: 10px; }
      .tiles::-webkit-scrollbar-thumb{ background: rgba(0,0,0,.08); border-radius: 999px; }
      .tiles::-webkit-scrollbar-track{ background: rgba(0,0,0,.02); border-radius: 999px; }

      .tile{
        flex: 0 0 auto;
        width: min(520px, 88vw);
        height: 400px;
        border-radius: var(--rXL);
        position: relative;
        overflow:hidden;
        scroll-snap-align: start;
        background: #fff;
        border: 1px solid rgba(0,0,0,.08);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        isolation: isolate;
      }

      .tiles .tile:nth-child(1){
        background-image: url("/webimageone.png");
      }
      .tiles .tile:nth-child(2){
        background-image: url("/webimagetwo.png");
      }
      .tiles .tile:nth-child(3){
        background-image: url("/webimageone.png");
      }

      .tile::after{
        content:"";
        position:absolute;
        inset:0;
        z-index:0;
        background:
          linear-gradient(
            180deg,
            rgba(255,255,255,.26) 0%,
            rgba(255,255,255,.12) 28%,
            rgba(255,255,255,.80) 72%,
            rgba(255,255,255,.92) 100%
          );
      }

      .tileText{
        position:absolute;
        inset: 0;
        padding: 24px;
        display:flex;
        flex-direction:column;
        justify-content:space-between;
        z-index:1;
      }
      .tileKicker{
        font-size: 13px;
        font-weight: 780;
        color: rgba(11,12,16,.66);
        letter-spacing: .15px;
      }
      .tileTitle{
        margin: 8px 0 0;
        font-size: 28px;
        letter-spacing: -0.7px;
        line-height: 1.05;
      }
      .tileSub{
        margin: 10px 0 0;
        color: rgba(11,12,16,.68);
        font-size: 15px;
        line-height: 1.35;
        max-width: 44ch;
      }
      .tileCta{
        display:inline-flex;
        align-items:center;
        gap:10px;
        font-weight: 800;
        font-size: 14px;
        letter-spacing: .1px;
        color: rgba(11,12,16,.86);
      }
      .tileCta svg{
        width:16px;
        height:16px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
      }

      .split{
        display:grid;
        gap: 22px;
        align-items:start;
      }
      @media (min-width: 980px){
        .split{ grid-template-columns: 1.1fr .9fr; }
      }

      .bigTitle{
        margin: 0;
        font-size: clamp(26px, 3.1vw, 44px);
        letter-spacing: -1px;
        line-height: 1.05;
      }
      .bigSub{
        margin: 12px 0 0;
        color: rgba(11,12,16,.68);
        font-size: 16px;
        line-height: 1.45;
        max-width: 62ch;
      }

      .floatShot{
        width: 100%;
        aspect-ratio: 4 / 5;
        border-radius: var(--rXL);
        background: #fff;
        border: 1px solid rgba(0,0,0,.08);
        background-image: url("/webimagetwo.png");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
      }

      .miniGrid{
        display:grid;
        gap: 18px;
        margin-top: 18px;
      }
      @media (min-width: 900px){
        .miniGrid{ grid-template-columns: repeat(3, minmax(0,1fr)); }
      }
      .mini{
        padding: 10px 2px;
      }
      .mini h3{
        margin: 0;
        font-size: 15px;
        letter-spacing: -.2px;
      }
      .mini p{
        margin: 10px 0 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.45;
        max-width: 46ch;
      }

      .footer{
        border-top: 1px solid rgba(0,0,0,.08);
        padding: 22px 0 40px;
        color: rgba(11,12,16,.62);
        font-size: 13px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
        flex-wrap: wrap;
        background:#fff;
      }
      .links{
        display:flex;
        gap: 14px;
        flex-wrap: wrap;
      }
      .links a{ color: rgba(11,12,16,.62); }
      .links a:hover{ color: rgba(11,12,16,.90); }

      /* ✅ Mobile tune */
      @media (max-width: 560px){
        .tile{ height: 360px; }
        .heroBannerWrap{ margin-bottom: 20px; }
        .heroInner{ padding: 26px 0 34px; }
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <div class="topbarInner">
        <a class="brand" href="/" aria-label="FLY Unlimited">
          <img class="mascot" src="/logo-alt.png" alt="FLY mascot" />
        </a>

        <nav class="nav" aria-label="Navigation">
          <a class="navBtn active" href="/" aria-label="Home" title="Home">
            <img class="navIcon" src="/flyhomeactive.svg" alt="" aria-hidden="true" />
          </a>

          <a class="navBtn" href="/how-it-works/" aria-label="How it works" title="How it works">
            <img class="navIcon" src="/flyinactive.svg" alt="" aria-hidden="true" />
          </a>

          <a class="navBtn" href="/info/" aria-label="Info" title="Info">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 10.6v6" />
              <path d="M12 7.4h.01" />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <section class="hero" aria-label="Hero">
      <div class="wrap heroInner">
        <div class="heroBannerWrap" aria-label="Landing hero banner">
          <HeroCategoryBanner />
        </div>

        <div class="heroKicker">
          <span class="dot" aria-hidden="true"></span>
          LiveTime collaboration, beautifully simple.
        </div>

        <div class="ctaRow" aria-label="Primary actions">
          <a class="btn btnPrimary" href={appStoreUrl} aria-label="App Store link">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14 7l-5 5 5 5"/>
              <path d="M9 12h12"/>
            </svg>
            Get the app
          </a>

          <a class="btn" href="/how-it-works/" aria-label="How it works">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M13 2 4 14h7l-1 8 10-14h-7z"/>
            </svg>
            How it works
          </a>
        </div>
      </div>
    </section>

    <section class="section" aria-label="Explore">
      <div class="wrap">
        <div class="tiles" aria-label="Feature tiles">
          <a class="tile" href="/how-it-works/" aria-label="Clarity tile">
            <div class="tileText">
              <div>
                <div class="tileKicker">Clarity</div>
                <div class="tileTitle">A checklist that stays clean.</div>
                <div class="tileSub">Materials, info, and goals — so everyone knows what “done” means.</div>
              </div>
              <div class="tileCta">
                Explore how it works
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
              </div>
            </div>
          </a>

          <a class="tile" href="/how-it-works/" aria-label="LiveTime tile">
            <div class="tileText">
              <div>
                <div class="tileKicker">LiveTime</div>
                <div class="tileTitle">Proof where it belongs.</div>
                <div class="tileSub">Photos, files, and updates inside each step — not buried in long threads.</div>
              </div>
              <div class="tileCta">
                See the flow
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
              </div>
            </div>
          </a>

          <a class="tile" href="/info/" aria-label="Momentum tile">
            <div class="tileText">
              <div>
                <div class="tileKicker">Momentum</div>
                <div class="tileTitle">Fast, real, and human.</div>
                <div class="tileSub">Connect, collaborate, exchange, and move forward — without friction.</div>
              </div>
              <div class="tileCta">
                Learn more
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="section" aria-label="Designed to feel effortless">
      <div class="wrap">
        <div class="split">
          <div>
            <h2 class="bigTitle">Designed to feel effortless.</h2>
            <p class="bigSub">
              FLY is built to keep work organized without feeling heavy.
              Clear steps. Clean media. Simple submission. Everything stays in the right place.
            </p>

            <div class="miniGrid" aria-label="Highlights">
              <div class="mini">
                <h3>Organized by default</h3>
                <p>Checklist items become threads — so proof and progress stay attached to the right step.</p>
              </div>
              <div class="mini">
                <h3>LiveTime momentum</h3>
                <p>Start, resume, message, and move. The flow stays fast and readable.</p>
              </div>
              <div class="mini">
                <h3>A polished finish</h3>
                <p>Submit with confidence — because everything is already organized for review.</p>
              </div>
            </div>
          </div>

          <div class="floatShot" role="img" aria-label="App screenshot placeholder"></div>
        </div>
      </div>
    </section>

    <footer class="wrap footer" aria-label="Footer">
      <div>© 2026 {siteName}</div>
      <div class="links">
        <a href="/how-it-works/">How it works</a>
        <a href="/info/">Contact</a>
        <a href="/terms/">Terms</a>
        <a href="/privacy/">Privacy</a>
        <a href={"mailto:" + contactEmail}>hello@fly-unlimited.com</a>
      </div>
    </footer>
  </body>
</html>
