---
const siteName = "FLY Unlimited";
const contactEmail = "hello@fly-unlimited.com"; // change if needed
const appStoreUrl = "#";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteName}</title>
    <meta name="description" content="It's Time to FLY." />

    <style>
      :root{
        --bg:#ffffff;
        --text:#0b0c10;
        --muted:rgba(11,12,16,.62);
        --hair:rgba(11,12,16,.10);

        --max:1120px;

        /* ✅ Wider on mobile, consistent everywhere */
        --pad: clamp(14px, 4.2vw, 18px);

        /* ✅ Subtle rounding only */
        --rXL: 32px;
        --rL: 26px;

        --ease: cubic-bezier(.2,.8,.2,1);
      }

      *{ box-sizing:border-box; }
      html,body{ margin:0; padding:0; }
      body{
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
        background: var(--bg);
        color: var(--text);
        line-height: 1.25;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      a{ color:inherit; text-decoration:none; }
      a:focus-visible{
        outline: 3px solid rgba(0,0,0,.18);
        outline-offset: 3px;
        border-radius: 12px;
      }

      /* ===== Top nav (clean, white) ===== */
      .topbar{
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(255,255,255,.92);
        border-bottom: 1px solid rgba(0,0,0,.06);
      }
      .topbarInner{
        max-width: var(--max);
        margin: 0 auto;
        padding: 10px var(--pad);
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
      }
      .brand{
        display:flex;
        align-items:center;
        gap:10px;
        min-height:44px;
      }
      .mascot{
        width:26px;height:26px;
        border-radius:10px;
        object-fit:contain;
        display:block;
      }

      .nav{
        display:flex;
        align-items:center;
        gap: 10px;
      }
      .navBtn{
        width:42px;height:42px;
        display:grid;
        place-items:center;
        border-radius: 999px;
        color: rgba(11,12,16,.72);
        transition: background .18s var(--ease), color .18s var(--ease);
      }
      .navBtn:hover{
        background: rgba(0,0,0,.05);
        color: rgba(11,12,16,.92);
      }
      .navBtn.active{
        background: rgba(0,0,0,.08);
        color: rgba(11,12,16,.96);
      }
      .navBtn svg{
        width:18px;height:18px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }

      /* ===== Sections ===== */
      .wrap{
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 var(--pad);
      }

      /* ===== HERO: white background + your image ===== */
      .hero{
        min-height: 92vh;
        display:grid;
        align-items:center;
        background: #fff;
      }

      .heroInner{
        padding: 68px 0 40px;
      }

      .heroGrid{
        display:grid;
        gap: 18px;
        align-items:center;
      }

      /* Desktop: image right, text left */
      @media (min-width: 980px){
        .heroGrid{
          grid-template-columns: 1.05fr .95fr;
          gap: 28px;
        }
        .heroInner{ padding: 84px 0 56px; }
      }

      .heroKicker{
        display:inline-flex;
        align-items:center;
        gap:10px;
        padding: 10px 14px;
        border-radius: 999px;
        background: #fff;
        border: 1px solid rgba(0,0,0,.10);
        color: rgba(11,12,16,.78);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: .2px;
      }
      .dot{
        width:10px;height:10px;border-radius:999px;
        background: rgba(108,43,217,1);
        /* ✅ no glow */
      }

      h1{
        margin: 18px 0 10px;
        font-size: clamp(34px, 5.0vw, 64px);
        letter-spacing: -1.3px;
        line-height: 1.02;
      }
      .heroSub{
        margin: 0;
        max-width: 60ch;
        font-size: clamp(16px, 1.65vw, 20px);
        color: rgba(11,12,16,.68);
        line-height: 1.38;
      }

      .ctaRow{
        margin-top: 18px;
        display:flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items:center;
      }

      .btn{
        display:inline-flex;
        align-items:center;
        justify-content:center;
        gap:10px;
        height: 44px;
        padding: 0 16px;
        border-radius: 999px;
        border: 1px solid rgba(0,0,0,.12);
        background: #fff;
        color: rgba(11,12,16,.92);
        font-weight: 760;
        font-size: 14px;
        letter-spacing: .1px;
        transition: transform .18s var(--ease), background .18s var(--ease);
      }
      .btn:hover{
        transform: translateY(-1px);
        background: rgba(0,0,0,.02);
      }

      .btnPrimary{
        border-color: transparent;
        background: #0b0c10;
        color: #fff;
      }
      .btnPrimary:hover{ background:#000; }

      .btn svg{
        width:16px;height:16px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }

      /* ✅ Hero image (no gray, no shadow, no overlay) */
      .heroImage{
        width: 100%;
        max-width: 980px;
        margin: 0 auto;
        border-radius: var(--rXL);
        overflow:hidden;
        background: #fff;
      }
      .heroImage img{
        width:100%;
        height:auto;
        display:block;
      }

      /* ===== Section ===== */
      .section{
        padding: 66px 0;
        background:#fff;
      }

      .sectionHeader{
        display:flex;
        align-items:flex-end;
        justify-content:space-between;
        gap: 14px;
        margin-bottom: 16px;
      }
      .sectionTitle{
        margin:0;
        font-size: clamp(22px, 2.2vw, 30px);
        letter-spacing:-.6px;
        line-height:1.08;
      }
      .sectionNote{
        margin:0;
        color: var(--muted);
        font-size: 14.5px;
        line-height:1.35;
        max-width: 60ch;
      }

      /* ===== Tiles: keep them white too ===== */
      .tiles{
        display:flex;
        gap: 16px;
        overflow-x: auto;
        padding-bottom: 6px;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
      }
      .tiles::-webkit-scrollbar{ height: 10px; }
      .tiles::-webkit-scrollbar-thumb{ background: rgba(0,0,0,.08); border-radius: 999px; }
      .tiles::-webkit-scrollbar-track{ background: rgba(0,0,0,.02); border-radius: 999px; }

      .tile{
        flex: 0 0 auto;
        width: min(520px, 88vw);
        height: 520px;
        border-radius: var(--rXL);
        position: relative;
        overflow:hidden;
        scroll-snap-align: start;

        /* ✅ no gradients, no shadows */
        background: #fff;
        border: 1px solid rgba(0,0,0,.08);
      }

      .tileText{
        position:absolute;
        inset: 0;
        padding: 26px 26px 22px;
        display:flex;
        flex-direction:column;
        justify-content:space-between;
        background: transparent; /* ✅ no overlay wash */
      }
      .tileKicker{
        font-size: 13px;
        font-weight: 780;
        color: rgba(11,12,16,.66);
        letter-spacing: .15px;
      }
      .tileTitle{
        margin: 8px 0 0;
        font-size: 30px;
        letter-spacing: -0.7px;
        line-height: 1.05;
      }
      .tileSub{
        margin: 10px 0 0;
        color: rgba(11,12,16,.68);
        font-size: 15px;
        line-height: 1.35;
        max-width: 38ch;
      }
      .tileCta{
        display:inline-flex;
        align-items:center;
        gap:10px;
        font-weight: 800;
        font-size: 14px;
        letter-spacing: .1px;
        color: rgba(11,12,16,.86);
      }
      .tileCta svg{
        width:16px;height:16px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
      }

      /* ===== Split ===== */
      .split{
        display:grid;
        gap: 22px;
        align-items:start;
      }
      @media (min-width: 980px){
        .split{ grid-template-columns: 1.1fr .9fr; }
      }

      .bigTitle{
        margin: 0;
        font-size: clamp(26px, 3.1vw, 44px);
        letter-spacing: -1px;
        line-height: 1.05;
      }
      .bigSub{
        margin: 12px 0 0;
        color: rgba(11,12,16,.68);
        font-size: 16px;
        line-height: 1.45;
        max-width: 62ch;
      }

      .floatShot{
        width: 100%;
        aspect-ratio: 4 / 5;
        border-radius: var(--rXL);
        background: #fff;              /* ✅ pure white */
        border: 1px solid rgba(0,0,0,.08);
      }

      .miniGrid{
        display:grid;
        gap: 18px;
        margin-top: 18px;
      }
      @media (min-width: 900px){
        .miniGrid{ grid-template-columns: repeat(3, minmax(0,1fr)); }
      }
      .mini{
        padding: 10px 2px;
      }
      .mini h3{
        margin: 0;
        font-size: 15px;
        letter-spacing: -.2px;
      }
      .mini p{
        margin: 10px 0 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.45;
        max-width: 46ch;
      }

      .footer{
        border-top: 1px solid rgba(0,0,0,.08);
        padding: 22px 0 40px;
        color: rgba(11,12,16,.62);
        font-size: 13px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
        flex-wrap: wrap;
        background:#fff;
      }
      .links{
        display:flex;
        gap: 14px;
        flex-wrap: wrap;
      }
      .links a{ color: rgba(11,12,16,.62); }
      .links a:hover{ color: rgba(11,12,16,.90); }

      /* ✅ Mobile tune */
      @media (max-width: 560px){
        .hero{ min-height: 86vh; }
        .heroInner{ padding: 52px 0 34px; }
        .tile{ height: 460px; border-radius: 30px; }
        .tileText{ padding: 22px; }
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <div class="topbarInner">
        <a class="brand" href="/" aria-label="FLY Unlimited">
          <img class="mascot" src="/logo-alt.png" alt="FLY mascot" />
        </a>

        <nav class="nav" aria-label="Navigation">
          <a class="navBtn active" href="/" aria-label="Home" title="Home">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3 10.5 12 3l9 7.5" />
              <path d="M5.5 9.8V21h13V9.8" />
            </svg>
          </a>

          <a class="navBtn" href="/how-it-works/" aria-label="How it works" title="How it works">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M13 2 4 14h7l-1 8 10-14h-7z" />
            </svg>
          </a>

          <a class="navBtn" href="/info/" aria-label="Info" title="Info">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 10.6v6" />
              <path d="M12 7.4h.01" />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <section class="hero" aria-label="Hero">
      <div class="wrap heroInner">
        <div class="heroGrid">
          <div>
            <div class="heroKicker">
              <span class="dot" aria-hidden="true"></span>
              LiveTime collaboration, beautifully simple.
            </div>

            <h1>It's Time to FLY.<br/>No Limits.</h1>
            <p class="heroSub">
              Its hard to find what you need, when you need it. Let's change that.
            </p>

            <div class="ctaRow" aria-label="Primary actions">
              <a class="btn btnPrimary" href={appStoreUrl} aria-label="App Store link">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 7l-5 5 5 5"/><path d="M9 12h12"/></svg>
                Get the app
              </a>

              <a class="btn" href="/how-it-works/" aria-label="How it works">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2 4 14h7l-1 8 10-14h-7z"/></svg>
                How it works
              </a>

              <a class="btn" href={"mailto:" + contactEmail} aria-label="Contact">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>
                Contact
              </a>
            </div>
          </div>

          <!-- ✅ Your uploaded image -->
          <div class="heroImage" aria-label="Landing hero image">
            <img src="/landin-hero.png" alt="FLY landing hero" />
          </div>
        </div>
      </div>
    </section>

    <section class="section" aria-label="Hey, what do you need">
      <div class="wrap">
        <div class="sectionHeader">
          <div>
            <h2 class="sectionTitle">Hey, what do you need?</h2>
            <p class="sectionNote">Join the Network and get what you need fast.</p>
          </div>
        </div>

        <div class="tiles" aria-label="Feature tiles">
          <a class="tile" href="/how-it-works/" aria-label="Clarity tile">
            <div class="tileText">
              <div>
                <div class="tileKicker">Clarity</div>
                <div class="tileTitle">A checklist that stays clean.</div>
                <div class="tileSub">Materials, info, and goals — so everyone knows what “done” means.</div>
              </div>
              <div class="tileCta">
                Explore how it works
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
              </div>
            </div>
          </a>

          <a class="tile" href="/how-it-works/" aria-label="LiveTime tile">
            <div class="tileText">
              <div>
                <div class="tileKicker">LiveTime</div>
                <div class="tileTitle">Proof where it belongs.</div>
                <div class="tileSub">Photos, files, and updates inside each step — not buried in long threads.</div>
              </div>
              <div class="tileCta">
                See the flow
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
              </div>
            </div>
          </a>

          <a class="tile" href="/info/" aria-label="Momentum tile">
            <div class="tileText">
              <div>
                <div class="tileKicker">Momentum</div>
                <div class="tileTitle">Fast, real, and human.</div>
                <div class="tileSub">Connect, collaborate, exchange, and move forward — without friction.</div>
              </div>
              <div class="tileCta">
                Learn more
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="section" aria-label="Designed to feel effortless">
      <div class="wrap">
        <div class="split">
          <div>
            <h2 class="bigTitle">Designed to feel effortless.</h2>
            <p class="bigSub">
              FLY is built to keep work organized without feeling heavy.
              Clear steps. Clean media. Simple submission. Everything stays in the right place.
            </p>

            <div class="miniGrid" aria-label="Highlights">
              <div class="mini">
                <h3>Organized by default</h3>
                <p>Checklist items become threads — so proof and progress stay attached to the right step.</p>
              </div>
              <div class="mini">
                <h3>LiveTime momentum</h3>
                <p>Start, resume, message, and move. The flow stays fast and readable.</p>
              </div>
              <div class="mini">
                <h3>A polished finish</h3>
                <p>Submit with confidence — because everything is already organized for review.</p>
              </div>
            </div>
          </div>

          <div class="floatShot" role="img" aria-label="App screenshot placeholder"></div>
        </div>
      </div>
    </section>

    <footer class="wrap footer" aria-label="Footer">
      <div>© 2026 {siteName}</div>
      <div class="links">
        <a href="/how-it-works/">How it works</a>
        <a href="/info/">Contact</a>
        <a href="/terms/">Terms</a>
        <a href="/privacy/">Privacy</a>
        <a href={"mailto:" + contactEmail}>hello@fly-unlimited.com</a>
      </div>
    </footer>
  </body>
</html>
