---
import HomeHeroBanner from "../components/HomeHeroBanner.astro";

const siteName = "FLY Unlimited";
const contactEmail = "hello@fly-unlimited.com"; // change if needed
const appStoreUrl = "#";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteName}</title>
    <meta name="description" content="It's Time to FLY." />

    <style>
      :root{
        --bg:#ffffff;
        --text:#0b0c10;
        --muted:rgba(11,12,16,.62);
        --main:#6C2BD9;

        --max:1120px;
        --pad: clamp(18px, 5vw, 22px);
        --featureGap: clamp(4px, 0.45vw, 8px);

        --rXL: 28px;
        --ease: cubic-bezier(.2,.8,.2,1);
        --topbarH: 64px;
      }

      *{ box-sizing:border-box; }

      html,body{
        margin:0;
        padding:0;
        background: var(--bg);
        overflow-x:hidden;
      }

      body{
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
        color: var(--text);
        line-height: 1.25;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a{
        color:inherit;
        text-decoration:none;
      }

      a:focus-visible{
        outline: 3px solid rgba(0,0,0,.18);
        outline-offset: 3px;
      }

      /* ===== Top nav: clean white ===== */
      .topbar{
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(255,255,255,.96);
        border-bottom: 1px solid rgba(0,0,0,.06);
        backdrop-filter: saturate(180%) blur(16px);
      }

      .topbarInner{
        max-width: var(--max);
        margin: 0 auto;
        padding: 10px var(--pad);
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
      }

      .brand{
        display:flex;
        align-items:center;
        gap:10px;
        min-height:44px;
      }

      .mascot{
        width:26px;
        height:26px;
        border-radius:10px;
        object-fit:contain;
        display:block;
      }

      .nav{
        display:flex;
        align-items:center;
        gap: 10px;
      }

      .navBtn{
        width:42px;
        height:42px;
        display:grid;
        place-items:center;
        border-radius: 999px;
        color: rgba(11,12,16,.72);
        transition: background .18s var(--ease), color .18s var(--ease);
      }

      .navBtn:hover{
        background: rgba(0,0,0,.05);
        color: rgba(11,12,16,.92);
      }

      .navBtn.active{
        background: rgba(0,0,0,.08);
        color: rgba(11,12,16,.96);
      }

      .navBtn svg{
        width:18px;
        height:18px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }

      .navIcon{
        width:18px;
        height:18px;
        display:block;
        object-fit:contain;
      }

      /* ===== Layout ===== */
      .wrap{
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 var(--pad);
      }

      /* ===== HERO ===== */
      .hero{
        background: #fff;
        min-height: calc(100svh - var(--topbarH));
        min-height: calc(100vh - var(--topbarH));
        display:block;
        overflow:hidden;
      }

      .heroInner{
        width:100%;
        max-width:none;
        padding:0;
        display:block;
      }

      .heroBannerWrap{
        width:100%;
        max-width:none;
        margin:0;
      }

      /* ===== Shared sections ===== */
      .section{
        padding: 60px 0;
        background:#fff;
      }

      .sectionHeader{
        display:flex;
        align-items:flex-end;
        justify-content:space-between;
        gap: 14px;
        margin-bottom: 16px;
      }

      .sectionTitle{
        margin:0;
        font-size: clamp(22px, 2.2vw, 30px);
        letter-spacing:-.6px;
        line-height:1.08;
      }

      .sectionNote{
        margin:0;
        color: var(--muted);
        font-size: 14.5px;
        line-height:1.35;
        max-width: 60ch;
      }

      /* ===== Edge-to-edge square feature band ===== */
      .featureBand{
        background:#fff;
        padding: clamp(16px, 1.8vw, 24px) 0 0;
        margin: 0;
      }

      .featureBandWrap{
        width:100%;
        margin:0;
        padding:0;
      }

      .featureGrid{
        display:grid;
        grid-template-columns: 1fr;
        gap: var(--featureGap);
      }

      .featureTile{
        position: relative;
        overflow:hidden;
        border-radius: 0;
        border: none;
        box-shadow: none;
        background-color:#f3f3f3;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        isolation: isolate;
        width: 100%;
        aspect-ratio: 1 / 1;
        min-height: 320px;
      }

      .featureGrid .featureTile:nth-child(1){
        background-image: url("/webimageone.png");
      }

      .featureGrid .featureTile:nth-child(2){
        background-image: url("/webimagetwo.png");
      }

      .featureGrid .featureTile:nth-child(3){
        background-image: url("/webimageone.png");
      }

      .featureTile::after{
        content:"";
        position:absolute;
        inset:0;
        z-index:0;
        background:
          linear-gradient(
            180deg,
            rgba(255,255,255,.14) 0%,
            rgba(255,255,255,.08) 28%,
            rgba(255,255,255,.72) 72%,
            rgba(255,255,255,.90) 100%
          );
      }

      .featureTileText{
        position:absolute;
        inset:0;
        z-index:1;
        padding: clamp(24px, 2vw, 34px);
        display:flex;
        flex-direction:column;
        justify-content:space-between;
      }

      .featureTileKicker{
        font-size: 13px;
        font-weight: 780;
        color: rgba(11,12,16,.64);
        letter-spacing: .15px;
      }

      .featureTileTitle{
        margin: 10px 0 0;
        font-size: clamp(28px, 2.4vw, 40px);
        letter-spacing: -.9px;
        line-height: 1.02;
        max-width: 11ch;
      }

      .featureTileSub{
        margin: 12px 0 0;
        color: rgba(11,12,16,.70);
        font-size: 15px;
        line-height: 1.4;
        max-width: 30ch;
      }

      .featureTileCta{
        display:inline-flex;
        align-items:center;
        gap:10px;
        font-weight: 800;
        font-size: 14px;
        letter-spacing: .1px;
        color: rgba(11,12,16,.88);
      }

      .featureTileCta svg{
        width:16px;
        height:16px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }

      @media (min-width: 980px){
        .featureGrid{
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .featureTile{
          min-height: 0;
          aspect-ratio: 1 / 1;
        }
      }

      @media (max-width: 979px){
        .featureGrid{
          grid-template-columns: 1fr;
        }

        .featureTile{
          aspect-ratio: 1 / 1;
        }

        .featureTileTitle{
          max-width: 12ch;
        }
      }

      /* ===== Secondary split section ===== */
      .split{
        display:grid;
        gap: 22px;
        align-items:start;
      }

      @media (min-width: 980px){
        .split{ grid-template-columns: 1.1fr .9fr; }
      }

      .bigTitle{
        margin: 0;
        font-size: clamp(26px, 3.1vw, 44px);
        letter-spacing: -1px;
        line-height: 1.05;
      }

      .bigSub{
        margin: 12px 0 0;
        color: rgba(11,12,16,.68);
        font-size: 16px;
        line-height: 1.45;
        max-width: 62ch;
      }

      .floatShot{
        width: 100%;
        aspect-ratio: 4 / 5;
        border-radius: var(--rXL);
        background: #fff;
        border: 1px solid rgba(0,0,0,.08);
        background-image: url("/webimagetwo.png");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
      }

      .miniGrid{
        display:grid;
        gap: 18px;
        margin-top: 18px;
      }

      @media (min-width: 900px){
        .miniGrid{ grid-template-columns: repeat(3, minmax(0,1fr)); }
      }

      .mini{
        padding: 10px 2px;
      }

      .mini h3{
        margin: 0;
        font-size: 15px;
        letter-spacing: -.2px;
      }

      .mini p{
        margin: 10px 0 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.45;
        max-width: 46ch;
      }

      .footer{
        border-top: 1px solid rgba(0,0,0,.08);
        padding: 22px 0 40px;
        color: rgba(11,12,16,.62);
        font-size: 13px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
        flex-wrap: wrap;
        background:#fff;
      }

      .links{
        display:flex;
        gap: 14px;
        flex-wrap: wrap;
      }

      .links a{ color: rgba(11,12,16,.62); }
      .links a:hover{ color: rgba(11,12,16,.90); }

      @media (max-width: 560px){
        .section{
          padding: 52px 0;
        }

        .featureTile{
          min-height: 280px;
        }
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <div class="topbarInner">
        <a class="brand" href="/" aria-label="FLY Unlimited">
          <img class="mascot" src="/logo-alt.png" alt="FLY mascot" />
        </a>

        <nav class="nav" aria-label="Navigation">
          <a class="navBtn active" href="/" aria-label="Home" title="Home">
            <img class="navIcon" src="/flyhomeactive.svg" alt="" aria-hidden="true" />
          </a>

          <a class="navBtn" href="/how-it-works/" aria-label="How it works" title="How it works">
            <img class="navIcon" src="/flyinactive.svg" alt="" aria-hidden="true" />
          </a>

          <a class="navBtn" href="/info/" aria-label="Info" title="Info">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 10.6v6" />
              <path d="M12 7.4h.01" />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <section class="hero" aria-label="Hero">
      <div class="heroInner">
        <div class="heroBannerWrap" aria-label="Landing hero banner">
          <HomeHeroBanner appStoreUrl={appStoreUrl} />
        </div>
      </div>
    </section>

    <section class="featureBand" aria-label="Explore">
      <div class="featureBandWrap">
        <div class="featureGrid" aria-label="Feature tiles">
          <a class="featureTile" href="/how-it-works/" aria-label="Clarity tile">
            <div class="featureTileText">
              <div>
                <div class="featureTileKicker">Clarity</div>
                <div class="featureTileTitle">A checklist that stays clean.</div>
                <div class="featureTileSub">
                  Materials, info, and goals — so everyone knows what “done” means.
                </div>
              </div>

              <div class="featureTileCta">
                Explore how it works
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M9 18l6-6-6-6" />
                </svg>
              </div>
            </div>
          </a>

          <a class="featureTile" href="/how-it-works/" aria-label="LiveTime tile">
            <div class="featureTileText">
              <div>
                <div class="featureTileKicker">LiveTime</div>
                <div class="featureTileTitle">Proof where it belongs.</div>
                <div class="featureTileSub">
                  Photos, files, and updates inside each step — not buried in long threads.
                </div>
              </div>

              <div class="featureTileCta">
                See the flow
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M9 18l6-6-6-6" />
                </svg>
              </div>
            </div>
          </a>

          <a class="featureTile" href="/info/" aria-label="Momentum tile">
            <div class="featureTileText">
              <div>
                <div class="featureTileKicker">Momentum</div>
                <div class="featureTileTitle">Fast, real, and human.</div>
                <div class="featureTileSub">
                  Connect, collaborate, exchange, and move forward — without friction.
                </div>
              </div>

              <div class="featureTileCta">
                Learn more
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M9 18l6-6-6-6" />
                </svg>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="section" aria-label="Designed to feel effortless">
      <div class="wrap">
        <div class="split">
          <div>
            <h2 class="bigTitle">Designed to feel effortless.</h2>
            <p class="bigSub">
              FLY is built to keep work organized without feeling heavy.
              Clear steps. Clean media. Simple submission. Everything stays in the right place.
            </p>

            <div class="miniGrid" aria-label="Highlights">
              <div class="mini">
                <h3>Organized by default</h3>
                <p>Checklist items become threads — so proof and progress stay attached to the right step.</p>
              </div>
              <div class="mini">
                <h3>LiveTime momentum</h3>
                <p>Start, resume, message, and move. The flow stays fast and readable.</p>
              </div>
              <div class="mini">
                <h3>A polished finish</h3>
                <p>Submit with confidence — because everything is already organized for review.</p>
              </div>
            </div>
          </div>

          <div class="floatShot" role="img" aria-label="App screenshot placeholder"></div>
        </div>
      </div>
    </section>

    <footer class="wrap footer" aria-label="Footer">
      <div>© 2026 {siteName}</div>
      <div class="links">
        <a href="/how-it-works/">How it works</a>
        <a href="/info/">Contact</a>
        <a href="/terms/">Terms</a>
        <a href="/privacy/">Privacy</a>
        <a href={"mailto:" + contactEmail}>hello@fly-unlimited.com</a>
      </div>
    </footer>
  </body>
</html>
