---
import HomeHeroBanner from "../components/HomeHeroBanner.astro";

const siteName = "FLY Unlimited";
const contactEmail = "hello@fly-unlimited.com";
const appStoreUrl = "https://apps.apple.com/us/app/fly-unlimited/id6758623880";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteName}</title>
    <meta name="description" content="It's Time to FLY." />

    <style>
      :root{
        --bg:#ffffff;
        --text:#0b0c10;
        --muted:rgba(11,12,16,.62);
        --main:#6C2BD9;

        --max:1120px;
        --pad: clamp(18px, 5vw, 22px);
        --featureGap: clamp(4px, 0.45vw, 8px);

        --ease: cubic-bezier(.2,.8,.2,1);
        --topbarH: 64px;
      }

      *{ box-sizing:border-box; }

      html,body{
        margin:0;
        padding:0;
        background: var(--bg);
        overflow-x:hidden;
      }

      body{
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
        color: var(--text);
        line-height: 1.25;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a{
        color:inherit;
        text-decoration:none;
      }

      a:focus-visible{
        outline: 3px solid rgba(0,0,0,.18);
        outline-offset: 3px;
      }

      /* ===== Top nav: clean white ===== */
      .topbar{
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(255,255,255,.96);
        border-bottom: 1px solid rgba(0,0,0,.06);
        backdrop-filter: saturate(180%) blur(16px);
      }

      .topbarInner{
        max-width: var(--max);
        margin: 0 auto;
        padding: 10px var(--pad);
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
      }

      .brand{
        display:flex;
        align-items:center;
        gap:10px;
        min-height:44px;
      }

      .mascot{
        width:26px;
        height:26px;
        border-radius:10px;
        object-fit:contain;
        display:block;
      }

      .nav{
        display:flex;
        align-items:center;
        gap: 10px;
      }

      .navBtn{
        width:42px;
        height:42px;
        display:grid;
        place-items:center;
        border-radius: 999px;
        color: rgba(11,12,16,.72);
        transition: background .18s var(--ease), color .18s var(--ease);
      }

      .navBtn:hover{
        background: rgba(0,0,0,.05);
        color: rgba(11,12,16,.92);
      }

      .navBtn.active{
        background: rgba(0,0,0,.08);
        color: rgba(11,12,16,.96);
      }

      .navBtn svg{
        width:18px;
        height:18px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }

      .navIcon{
        width:18px;
        height:18px;
        display:block;
        object-fit:contain;
      }

      /* ===== Layout ===== */
      .wrap{
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 var(--pad);
      }

      /* ===== HERO ===== */
      .hero{
        background: #fff;
        min-height: calc(100svh - var(--topbarH));
        min-height: calc(100vh - var(--topbarH));
        display:block;
        overflow:hidden;
      }

      .heroInner{
        width:100%;
        max-width:none;
        padding:0;
        display:block;
      }

      .heroBannerWrap{
        width:100%;
        max-width:none;
        margin:0;
      }

      /* ===== Edge-to-edge feature band ===== */
      .featureBand{
        background:#fff;
        padding: clamp(6px, 0.8vw, 10px) 0 0;
        margin: 0;
      }

      .featureBandWrap{
        width:100%;
        margin:0;
        padding:0;
      }

      .featureGrid{
        display:grid;
        grid-template-columns: 1fr;
        gap: var(--featureGap);
      }

      .featureTile{
        position: relative;
        overflow:hidden;
        border-radius: 0;
        border: none;
        box-shadow: none;
        background-color:#f3f3f3;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        isolation: isolate;
        width: 100%;
      }

      .featureGrid .featureTile:nth-child(1){
        background-image: url("/webimageone.png");
      }

      .featureGrid .featureTile:nth-child(2){
        background-image: url("/webimagetwo.png");
      }

      .featureGrid .featureTile:nth-child(3){
        background-image: url("/webimagethree.png");
      }

      .featureTile::after{
        content:"";
        position:absolute;
        inset:0;
        z-index:0;
        background: linear-gradient(
          180deg,
          rgba(0,0,0,0.02) 0%,
          rgba(0,0,0,0.08) 46%,
          rgba(0,0,0,0.42) 100%
        );
      }

      .featureTileText{
        position:absolute;
        inset:0;
        z-index:1;
        padding: clamp(20px, 2vw, 28px);
        display:flex;
        flex-direction:column;
        justify-content:flex-end;
        align-items:flex-start;
        gap: 12px;
      }

      .featureTileKicker{
        font-size: 11px;
        font-weight: 760;
        color: rgba(255,255,255,.82);
        letter-spacing: .14em;
        text-transform: uppercase;
      }

      .featureTileTitle{
        margin: 8px 0 0;
        font-size: clamp(24px, 2vw, 34px);
        font-weight: 700;
        letter-spacing: -.04em;
        line-height: 1.02;
        max-width: 10ch;
        color: #fff;
        text-shadow: 0 1px 10px rgba(0,0,0,.18);
      }

      .featureTileSub{
        margin: 10px 0 0;
        color: rgba(255,255,255,.88);
        font-size: 14px;
        line-height: 1.42;
        max-width: 24ch;
        text-shadow: 0 1px 8px rgba(0,0,0,.18);
      }

      .featureTileCta{
        display:inline-flex;
        align-items:center;
        gap:8px;
        font-weight: 700;
        font-size: 13px;
        letter-spacing: .01em;
        color: rgba(255,255,255,.96);
        text-shadow: 0 1px 8px rgba(0,0,0,.18);
      }

      .featureTileCta svg{
        width:15px;
        height:15px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }

      /* Desktop: keep them square */
      @media (min-width: 980px){
        .featureGrid{
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .featureTile{
          aspect-ratio: 1 / 1;
          min-height: 0;
        }
      }

      /* Tablet / mobile */
      @media (max-width: 979px){
        .featureGrid{
          grid-template-columns: 1fr;
        }

        .featureTile{
          aspect-ratio: 16 / 10;
          min-height: clamp(240px, 56vw, 420px);
        }

        .featureTileTitle{
          max-width: 11ch;
        }
      }

      @media (max-width: 560px){
        .featureTile{
          aspect-ratio: 6 / 5;
          min-height: 250px;
        }

        .featureTileText{
          padding: 20px;
          gap: 10px;
        }

        .featureTileTitle{
          font-size: clamp(22px, 7vw, 30px);
          max-width: 10ch;
        }

        .featureTileSub{
          font-size: 13px;
          max-width: 22ch;
        }

        .featureTileCta{
          font-size: 12.5px;
        }
      }

      .footer{
        border-top: 1px solid rgba(0,0,0,.08);
        padding: 22px 0 40px;
        color: rgba(11,12,16,.62);
        font-size: 13px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
        flex-wrap: wrap;
        background:#fff;
      }

      .links{
        display:flex;
        gap: 14px;
        flex-wrap: wrap;
      }

      .links a{ color: rgba(11,12,16,.62); }
      .links a:hover{ color: rgba(11,12,16,.90); }
    </style>
  </head>

  <body>
    <header class="topbar">
      <div class="topbarInner">
        <a class="brand" href="/" aria-label="FLY Unlimited">
          <img class="mascot" src="/logo-alt.png" alt="FLY mascot" />
        </a>

        <nav class="nav" aria-label="Navigation">
          <a class="navBtn active" href="/" aria-label="Home" title="Home">
            <img class="navIcon" src="/flyhomeactive.svg" alt="" aria-hidden="true" />
          </a>

          <a class="navBtn" href="/how-it-works/" aria-label="How it works" title="How it works">
            <img class="navIcon" src="/flyinactive.svg" alt="" aria-hidden="true" />
          </a>

          <a class="navBtn" href="/info/" aria-label="Info" title="Info">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 10.6v6" />
              <path d="M12 7.4h.01" />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <section class="hero" aria-label="Hero">
      <div class="heroInner">
        <div class="heroBannerWrap" aria-label="Landing hero banner">
          <HomeHeroBanner appStoreUrl={appStoreUrl} />
        </div>
      </div>
    </section>

    <section class="featureBand" aria-label="Explore">
      <div class="featureBandWrap">
        <div class="featureGrid" aria-label="Feature tiles">
          <a class="featureTile" href="/how-it-works/" aria-label="Clarity tile">
            <div class="featureTileText">
              <div>
                <div class="featureTileKicker">Clarity</div>
                <div class="featureTileTitle">With you, wherever.</div>
                <div class="featureTileSub">
                  As you move, so should your network.
                </div>
              </div>

              <div class="featureTileCta">
                Explore how it works
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M9 18l6-6-6-6" />
                </svg>
              </div>
            </div>
          </a>

          <a class="featureTile" href="/how-it-works/" aria-label="LiveTime tile">
            <div class="featureTileText">
              <div>
                <div class="featureTileKicker">LiveTime</div>
                <div class="featureTileTitle">Collabs. Easy.</div>
                <div class="featureTileSub">
                  Nothing like teamwork, when you want to go far.
                </div>
              </div>

              <div class="featureTileCta">
                See the flow
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M9 18l6-6-6-6" />
                </svg>
              </div>
            </div>
          </a>

          <a class="featureTile" href="/info/" aria-label="Momentum tile">
            <div class="featureTileText">
              <div>
                <div class="featureTileKicker">Momentum</div>
                <div class="featureTileTitle">Now, not later.</div>
                <div class="featureTileSub">
                  Connect and move forward. Then move forward again.
                </div>
              </div>

              <div class="featureTileCta">
                Learn more
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M9 18l6-6-6-6" />
                </svg>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <footer class="wrap footer" aria-label="Footer">
      <div>© 2026 {siteName}</div>
      <div class="links">
        <a href="/how-it-works/">How it works</a>
        <a href="/info/">Contact</a>
        <a href="/terms/">Terms</a>
        <a href="/privacy/">Privacy</a>
        <a href={"mailto:" + contactEmail}>hello@fly-unlimited.com</a>
      </div>
    </footer>
  </body>
</html>
