---
const siteName = "FLY Unlimited";

// ✅ Put the email you want public here (recommended: hello@ / contact@ / support@)
const publicEmail = "contact@fly-unlimited.com";

// Optional: your personal/admin email (not shown publicly unless you want it)
const adminEmail = "name.lastname@yourdomain.com";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Info • {siteName}</title>
    <meta name="description" content="Contact and basic information for FLY Unlimited." />

    <style>
      :root{
        --bg:#ffffff;
        --text:#0b0c10;
        --muted:rgba(11,12,16,.62);
        --hair:rgba(11,12,16,.10);

        --main:#6C2BD9;
        --mainSoft: rgba(108,43,217,.14);

        --max:1120px;

        --rXL: 34px;
        --rL: 28px;
        --rM: 22px;

        --shadowFloat: 0 22px 60px rgba(0,0,0,.14);
        --shadowSoft: 0 18px 46px rgba(0,0,0,.10);

        --ease: cubic-bezier(.2,.8,.2,1);
      }

      *{ box-sizing:border-box; }
      html,body{ margin:0; padding:0; }
      body{
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        line-height: 1.25;
      }

      a{ color:inherit; text-decoration:none; }
      a:hover{ opacity:.96; }
      a:focus-visible{
        outline: 3px solid rgba(108,43,217,.35);
        outline-offset: 3px;
        border-radius: 12px;
      }

      /* ===== Top nav ===== */
      .topbar{
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: saturate(180%) blur(14px);
        background: rgba(255,255,255,.78);
        border-bottom: 1px solid rgba(0,0,0,.06);
      }
      .topbarInner{
        max-width: var(--max);
        margin: 0 auto;
        padding: 10px 18px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
      }
      .brand{
        display:flex;
        align-items:center;
        gap:10px;
        min-height:44px;
      }
      .mascot{
        width:26px;height:26px;
        border-radius:10px;
        object-fit:contain;
        display:block;
      }

      .nav{ display:flex; align-items:center; gap:10px; }
      .navBtn{
        width:42px;height:42px;
        display:grid;
        place-items:center;
        border-radius:999px;
        color: rgba(11,12,16,.70);
        transition: background .18s var(--ease), color .18s var(--ease);
      }
      .navBtn:hover{ background: rgba(0,0,0,.05); color: rgba(11,12,16,.92); }
      .navBtn.active{ background: rgba(0,0,0,.10); color: rgba(11,12,16,.96); }
      .navBtn svg{
        width:18px;height:18px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }

      /* ===== Layout ===== */
      .wrap{
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 18px;
      }
      .section{ padding: 84px 0; }
      @media (max-width: 700px){
        .section{ padding: 66px 0; }
      }

      /* ===== Hero ===== */
      .hero{
        padding: 86px 0 58px;
        background:
          radial-gradient(900px 420px at 18% 18%, rgba(108,43,217,.16), transparent 58%),
          radial-gradient(780px 420px at 82% 26%, rgba(0,0,0,.06), transparent 55%),
          linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(250,250,252,1) 70%, rgba(255,255,255,1) 100%);
      }
      .kicker{
        display:inline-flex;
        align-items:center;
        gap:10px;
        padding: 10px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.72);
        border: 1px solid rgba(0,0,0,.08);
        color: rgba(11,12,16,.78);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: .2px;
        backdrop-filter: blur(10px);
      }
      .dot{
        width:9px;height:9px;border-radius:999px;
        background: var(--main);
        box-shadow: 0 0 0 7px var(--mainSoft);
      }

      h1{
        margin: 18px 0 10px;
        font-size: clamp(34px, 5.0vw, 66px);
        letter-spacing: -1.4px;
        line-height: 1.02;
      }
      .sub{
        margin: 0;
        max-width: 70ch;
        font-size: clamp(16px, 1.55vw, 20px);
        color: rgba(11,12,16,.68);
        line-height: 1.45;
      }

      .ctaRow{
        margin-top: 18px;
        display:flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items:center;
      }
      .btn{
        display:inline-flex;
        align-items:center;
        justify-content:center;
        gap:10px;
        height: 44px;
        padding: 0 16px;
        border-radius: 999px;
        border: 1px solid rgba(0,0,0,.10);
        background: rgba(255,255,255,.90);
        color: rgba(11,12,16,.92);
        font-weight: 760;
        font-size: 14px;
        letter-spacing: .1px;
        transition: transform .18s var(--ease), background .18s var(--ease), box-shadow .18s var(--ease);
      }
      .btn:hover{
        transform: translateY(-1px);
        box-shadow: 0 16px 40px rgba(0,0,0,.10);
        background: rgba(255,255,255,.96);
      }
      .btnPrimary{
        border-color: transparent;
        background: var(--text);
        color: #fff;
        box-shadow: 0 18px 48px rgba(0,0,0,.18);
      }
      .btnPrimary:hover{ background:#000; }
      .btn svg{
        width:16px;height:16px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }

      /* ===== Floating hero image ===== */
      .float{
        width: 100%;
        border-radius: var(--rXL);
        box-shadow: var(--shadowFloat);
        background:
          radial-gradient(700px 480px at 60% 20%, rgba(108,43,217,.18), transparent 58%),
          radial-gradient(650px 520px at 30% 55%, rgba(0,0,0,.10), transparent 58%),
          linear-gradient(180deg, #f6f6f8 0%, #ffffff 70%),
          url("/info/hero.jpg");
        background-size: cover;
        background-position: center;
        overflow:hidden;
      }
      .float.heroShot{ aspect-ratio: 16 / 9; margin-top: 26px; }

      /* ===== Content blocks (Apple hairline style, no cards) ===== */
      .grid{
        display:grid;
        gap: 34px;
        margin-top: 38px;
      }
      @media (min-width: 980px){
        .grid{ grid-template-columns: 1.05fr .95fr; }
      }

      .blockTitle{
        margin: 0;
        font-size: 18px;
        letter-spacing: -.3px;
      }
      .blockSub{
        margin: 10px 0 0;
        color: rgba(11,12,16,.68);
        font-size: 15.5px;
        line-height: 1.55;
        max-width: 70ch;
      }

      .rows{
        margin-top: 18px;
        border-top: 1px solid rgba(0,0,0,.10);
      }
      .row{
        padding: 14px 0;
        border-bottom: 1px solid rgba(0,0,0,.10);
        display:flex;
        align-items:flex-start;
        justify-content:space-between;
        gap: 16px;
        flex-wrap: wrap;
      }
      .rowLabel{
        color: rgba(11,12,16,.62);
        font-weight: 760;
        font-size: 13px;
        letter-spacing: .12px;
      }
      .rowValue{
        font-size: 15px;
        color: rgba(11,12,16,.92);
        font-weight: 650;
      }
      .rowValue a{
        text-decoration: underline;
        text-underline-offset: 3px;
      }
      .rowHint{
        margin-top: 8px;
        color: rgba(11,12,16,.60);
        font-size: 13.8px;
        line-height: 1.55;
        max-width: 72ch;
      }

      /* ===== Footer ===== */
      .footer{
        border-top: 1px solid rgba(0,0,0,.08);
        padding: 22px 0 40px;
        color: rgba(11,12,16,.62);
        font-size: 13px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
        flex-wrap: wrap;
      }
      .links{
        display:flex;
        gap: 14px;
        flex-wrap: wrap;
      }
      .links a{ color: rgba(11,12,16,.62); }
      .links a:hover{ color: rgba(11,12,16,.90); }
    </style>
  </head>

  <body>
    <header class="topbar">
      <div class="topbarInner">
        <a class="brand" href="/" aria-label="FLY Unlimited">
          <img class="mascot" src="/logo-alt.png" alt="FLY mascot" />
        </a>

        <nav class="nav" aria-label="Navigation">
          <a class="navBtn" href="/" aria-label="Home" title="Home">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3 10.5 12 3l9 7.5" />
              <path d="M5.5 9.8V21h13V9.8" />
            </svg>
          </a>

          <a class="navBtn" href="/how-it-works/" aria-label="How it works" title="How it works">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M13 2 4 14h7l-1 8 10-14h-7z" />
            </svg>
          </a>

          <a class="navBtn active" href="/info/" aria-label="Info" title="Info">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 10.6v6" />
              <path d="M12 7.4h.01" />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <!-- ===== HERO ===== -->
    <section class="hero" aria-label="Info hero">
      <div class="wrap">
        <div class="kicker"><span class="dot" aria-hidden="true"></span>Info</div>

        <h1>Contact & updates.</h1>
        <p class="sub">
          A clean point of contact for support, enrollment, partnerships, and product updates.
        </p>

        <div class="ctaRow" aria-label="Primary actions">
          <a class="btn btnPrimary" href={`mailto:${publicEmail}`} aria-label="Email public contact">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>
            Email {publicEmail}
          </a>

          <a class="btn" href="/how-it-works/" aria-label="How it works">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2 4 14h7l-1 8 10-14h-7z"/></svg>
            How it works
          </a>
        </div>

        <!-- Floating image placeholder -->
        <div class="float heroShot" role="img" aria-label="Info hero image placeholder"></div>
      </div>
    </section>

    <!-- ===== CONTENT ===== -->
    <section class="section" aria-label="Info content">
      <div class="wrap">
        <div class="grid">
          <!-- Left: Contact -->
          <div>
            <h2 class="blockTitle">Contact</h2>
            <p class="blockSub">
              Use the email below for anything: questions, early access, support, or partnerships.
              We keep it simple.
            </p>

            <div class="rows" aria-label="Contact rows">
              <div class="row">
                <div>
                  <div class="rowLabel">Public email</div>
                  <div class="rowHint">This is the best way to reach FLY Unlimited.</div>
                </div>
                <div class="rowValue"><a href={`mailto:${publicEmail}`}>{publicEmail}</a></div>
              </div>

              <div class="row">
                <div>
                  <div class="rowLabel">Status</div>
                  <div class="rowHint">We’re actively building. Launch updates will be shared as we get closer.</div>
                </div>
                <div class="rowValue">In development • Coming soon</div>
              </div>

              <div class="row">
                <div>
                  <div class="rowLabel">Response time</div>
                  <div class="rowHint">We reply as fast as possible — usually within 24–48 hours.</div>
                </div>
                <div class="rowValue">Fast</div>
              </div>
            </div>
          </div>

          <!-- Right: Legal / links -->
          <div>
            <h2 class="blockTitle">Basics</h2>
            <p class="blockSub">
              Everything you need in one place — privacy, terms, and where to learn how it works.
            </p>

            <div class="rows" aria-label="Basics rows">
              <div class="row">
                <div>
                  <div class="rowLabel">How it works</div>
                  <div class="rowHint">The full LiveTime flow, step by step.</div>
                </div>
                <div class="rowValue"><a href="/how-it-works/">View</a></div>
              </div>

              <div class="row">
                <div>
                  <div class="rowLabel">Privacy</div>
                  <div class="rowHint">How we handle data and user information.</div>
                </div>
                <div class="rowValue"><a href="/privacy/">Privacy</a></div>
              </div>

              <div class="row">
                <div>
                  <div class="rowLabel">Terms</div>
                  <div class="rowHint">Product usage and platform rules.</div>
                </div>
                <div class="rowValue"><a href="/terms/">Terms</a></div>
              </div>
            </div>

            <!-- If you ever want to show admin email, uncomment:
            <div class="rows" style="margin-top:18px;">
              <div class="row">
                <div>
                  <div class="rowLabel">Admin</div>
                  <div class="rowHint">Private / internal use.</div>
                </div>
                <div class="rowValue"><a href={`mailto:${adminEmail}`}>{adminEmail}</a></div>
              </div>
            </div>
            -->
          </div>
        </div>
      </div>
    </section>

    <footer class="wrap footer" aria-label="Footer">
      <div>© 2026 {siteName}</div>
      <div class="links">
        <a href="/">Home</a>
        <a href="/how-it-works/">How it works</a>
        <a href="/terms/">Terms</a>
        <a href="/privacy/">Privacy</a>
        <a href={`mailto:${publicEmail}`}>{publicEmail}</a>
      </div>
    </footer>
  </body>
</html>
