---
const siteName = "FLY Unlimited";
const publicEmail = "contact@fly-unlimited.com";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Info • {siteName}</title>
    <meta name="description" content="Contact and basic information for FLY Unlimited." />

    <style>
      :root{
        --bg:#ffffff;
        --text:#0b0c10;
        --muted:rgba(11,12,16,.62);
        --hair:rgba(11,12,16,.10);
        --hairStrong:rgba(11,12,16,.14);
        --max:1120px;
        --rXL:34px;
        --rL:28px;
        --rM:22px;
        --ease:cubic-bezier(.2,.8,.2,1);
      }

      *{ box-sizing:border-box; }
      html,body{ margin:0; padding:0; }
      body{
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        line-height: 1.25;
      }

      a{ color:inherit; text-decoration:none; }
      a:hover{ opacity:.96; }
      a:focus-visible{
        outline: 3px solid rgba(0,0,0,.16);
        outline-offset: 3px;
        border-radius: 12px;
      }

      /* ===== Top nav ===== */
      .topbar{
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(255,255,255,.96);
        border-bottom: 1px solid rgba(0,0,0,.06);
      }
      .topbarInner{
        max-width: var(--max);
        margin: 0 auto;
        padding: 10px 18px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:14px;
      }
      .brand{
        display:flex;
        align-items:center;
        gap:10px;
        min-height:44px;
      }
      .mascot{
        width:26px;
        height:26px;
        border-radius:10px;
        object-fit:contain;
        display:block;
      }

      .nav{
        display:flex;
        align-items:center;
        gap:10px;
      }
      .navBtn{
        width:42px;
        height:42px;
        display:grid;
        place-items:center;
        border-radius:999px;
        color: rgba(11,12,16,.70);
        transition: background .18s var(--ease), color .18s var(--ease);
      }
      .navBtn:hover{
        background: rgba(0,0,0,.05);
        color: rgba(11,12,16,.92);
      }
      .navBtn.active{
        background: rgba(0,0,0,.08);
        color: rgba(11,12,16,.96);
      }
      .navBtn svg{
        width:18px;
        height:18px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }
      .navIcon{
        width:18px;
        height:18px;
        display:block;
        object-fit:contain;
      }

      /* ===== Layout ===== */
      .wrap{
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 18px;
      }

      /* ===== Hero ===== */
      .hero{
        padding: 84px 0 54px;
        background:#fff;
        border-bottom: 1px solid rgba(0,0,0,.05);
      }

      .heroInner{
        max-width: 860px;
      }

      .kicker{
        display:inline-flex;
        align-items:center;
        gap:10px;
        padding: 9px 13px;
        border-radius: 999px;
        background: #fff;
        border: 1px solid rgba(0,0,0,.10);
        color: rgba(11,12,16,.78);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: .2px;
      }
      .dot{
        width:8px;
        height:8px;
        border-radius:999px;
        background: rgba(11,12,16,.88);
      }

      h1{
        margin: 18px 0 12px;
        font-size: clamp(34px, 5vw, 62px);
        letter-spacing: -1.3px;
        line-height: 1.02;
        max-width: 10ch;
      }
      .sub{
        margin: 0;
        max-width: 58ch;
        font-size: clamp(16px, 1.55vw, 20px);
        color: rgba(11,12,16,.68);
        line-height: 1.5;
      }

      .ctaRow{
        margin-top: 22px;
        display:flex;
        gap:12px;
        flex-wrap:wrap;
        align-items:center;
      }
      .btn{
        display:inline-flex;
        align-items:center;
        justify-content:center;
        gap:10px;
        height:44px;
        padding: 0 16px;
        border-radius:999px;
        border:1px solid rgba(0,0,0,.12);
        background:#fff;
        color: rgba(11,12,16,.92);
        font-weight:760;
        font-size:14px;
        letter-spacing:.1px;
        transition: transform .18s var(--ease), background .18s var(--ease), border-color .18s var(--ease);
      }
      .btn:hover{
        transform: translateY(-1px);
        background: rgba(0,0,0,.02);
        border-color: rgba(0,0,0,.16);
      }
      .btnPrimary{
        border-color: transparent;
        background:#0b0c10;
        color:#fff;
      }
      .btnPrimary:hover{ background:#000; }
      .btn svg{
        width:16px;
        height:16px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }

      .heroImage{
        width:100%;
        aspect-ratio: 16 / 9;
        margin-top: 34px;
        border-radius: 30px;
        border: 1px solid rgba(0,0,0,.08);
        background: #f7f7f7 url("/info/hero.jpg") center / cover no-repeat;
        overflow:hidden;
      }

      /* ===== Simple content ===== */
      .section{
        padding: 72px 0 84px;
        background:#fff;
      }

      .contentGrid{
        display:grid;
        gap:22px;
      }
      @media (min-width: 900px){
        .contentGrid{
          grid-template-columns: repeat(3, minmax(0,1fr));
        }
      }

      .card{
        border: 1px solid rgba(0,0,0,.08);
        border-radius: var(--rM);
        padding: 22px;
        background:#fff;
      }
      .cardTitle{
        margin:0;
        font-size:18px;
        letter-spacing:-.3px;
      }
      .cardText{
        margin:10px 0 0;
        color: rgba(11,12,16,.68);
        font-size:15.5px;
        line-height:1.6;
      }
      .inlineLink{
        display:inline-flex;
        align-items:center;
        gap:8px;
        margin-top:14px;
        font-size:14px;
        font-weight:700;
        color: rgba(11,12,16,.84);
      }
      .inlineLink svg{
        width:15px;
        height:15px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }

      /* ===== Footer ===== */
      .footer{
        border-top: 1px solid rgba(0,0,0,.08);
        padding: 22px 0 40px;
        color: rgba(11,12,16,.62);
        font-size: 13px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:14px;
        flex-wrap:wrap;
      }
      .links{
        display:flex;
        gap:14px;
        flex-wrap:wrap;
      }
      .links a{ color: rgba(11,12,16,.62); }
      .links a:hover{ color: rgba(11,12,16,.90); }

      @media (max-width: 820px){
        .hero{
          padding: 68px 0 46px;
        }
        .heroImage{
          margin-top: 28px;
        }
      }

      @media (max-width: 560px){
        .topbarInner,
        .wrap{
          padding-left:16px;
          padding-right:16px;
        }
        h1{
          max-width:none;
        }
        .card{
          padding:18px;
        }
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <div class="topbarInner">
        <a class="brand" href="/" aria-label="FLY Unlimited">
          <img class="mascot" src="/logo-alt.png" alt="FLY mascot" />
        </a>

        <nav class="nav" aria-label="Navigation">
          <a class="navBtn" href="/" aria-label="Home" title="Home">
            <img class="navIcon" src="/flyhome.svg" alt="" aria-hidden="true" />
          </a>

          <a class="navBtn" href="/how-it-works/" aria-label="How it works" title="How it works">
            <img class="navIcon" src="/flyinactive.svg" alt="" aria-hidden="true" />
          </a>

          <a class="navBtn active" href="/info/" aria-label="Info" title="Info">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 10.6v6" />
              <path d="M12 7.4h.01" />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <section class="hero" aria-label="Info hero">
      <div class="wrap heroInner">
        <div class="kicker"><span class="dot" aria-hidden="true"></span>Info</div>

        <h1>Simple, clear, and easy to reach.</h1>
        <p class="sub">
          FLY keeps things light. Reach out for support, questions, partnerships, or early access.
        </p>

        <div class="ctaRow" aria-label="Primary actions">
          <a class="btn btnPrimary" href={`mailto:${publicEmail}`} aria-label="Contact">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 6h16v12H4z"/>
              <path d="m4 7 8 6 8-6"/>
            </svg>
            Contact
          </a>

          <a class="btn" href="/how-it-works/" aria-label="How it works">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M13 2 4 14h7l-1 8 10-14h-7z"/>
            </svg>
            How it works
          </a>
        </div>

        <div class="heroImage" role="img" aria-label="Info hero image placeholder"></div>
      </div>
    </section>

    <section class="section" aria-label="Info content">
      <div class="wrap">
        <div class="contentGrid">
          <div class="card">
            <h2 class="cardTitle">Contact</h2>
            <p class="cardText">
              Questions, support, partnerships, or anything else. Keep it simple and send us a message.
            </p>
            <a class="inlineLink" href={`mailto:${publicEmail}`} aria-label="Contact FLY">
              Contact
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 12h14"/>
                <path d="m13 6 6 6-6 6"/>
              </svg>
            </a>
          </div>

          <div class="card">
            <h2 class="cardTitle">How it works</h2>
            <p class="cardText">
              See the LiveTime flow from start to finish and understand how FLY stays organized.
            </p>
            <a class="inlineLink" href="/how-it-works/" aria-label="View how it works">
              View page
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 12h14"/>
                <path d="m13 6 6 6-6 6"/>
              </svg>
            </a>
          </div>

          <div class="card">
            <h2 class="cardTitle">Privacy</h2>
            <p class="cardText">
              Read the basics on how information is handled across the platform.
            </p>
            <a class="inlineLink" href="/privacy/" aria-label="View privacy page">
              View page
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 12h14"/>
                <path d="m13 6 6 6-6 6"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <footer class="wrap footer" aria-label="Footer">
      <div>© 2026 {siteName}</div>
      <div class="links">
        <a href="/">Home</a>
        <a href="/how-it-works/">How it works</a>
        <a href="/terms/">Terms</a>
        <a href="/privacy/">Privacy</a>
        <a href={`mailto:${publicEmail}`}>Contact</a>
      </div>
    </footer>
  </body>
</html>
