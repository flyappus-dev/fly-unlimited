---
export const prerender = true;

const title = "Privacy Policy — FLY Unlimited (FLY)";
const effectiveDate = "February 11, 2026";
const siteName = "FLY Unlimited";
const contactEmail = "contact@fly-unlimited.com";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="robots" content="index,follow" />
    <style>
      :root{
        color-scheme: light;
        --bg:#ffffff;
        --text:#0b0c10;
        --muted:rgba(11,12,16,.62);
        --main:#6C2BD9;
        --max:1120px;
        --ease: cubic-bezier(.2,.8,.2,1);
      }

      *{ box-sizing:border-box; }

      html,body{
        margin:0;
        padding:0;
        background:#fff;
      }

      body{
        font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a{
        color: #000;
        text-decoration: underline;
      }

      a:focus-visible{
        outline: 3px solid rgba(108,43,217,.35);
        outline-offset: 3px;
        border-radius: 12px;
      }

      /* ===== Top nav ===== */
      .topbar{
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: saturate(180%) blur(14px);
        background: rgba(255,255,255,.78);
        border-bottom: 1px solid rgba(0,0,0,.06);
      }
      .topbarInner{
        max-width: var(--max);
        margin: 0 auto;
        padding: 10px 18px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
      }
      .brand{
        display:flex;
        align-items:center;
        gap:10px;
        min-height:44px;
        text-decoration:none;
      }
      .mascot{
        width:26px;
        height:26px;
        border-radius:10px;
        object-fit:contain;
        display:block;
      }

      .nav{
        display:flex;
        align-items:center;
        gap:10px;
      }
      .navBtn{
        width:42px;
        height:42px;
        display:grid;
        place-items:center;
        border-radius:999px;
        color: rgba(11,12,16,.70);
        text-decoration:none;
        transition: background .18s var(--ease), color .18s var(--ease);
      }
      .navBtn:hover{
        background: rgba(0,0,0,.05);
        color: rgba(11,12,16,.92);
      }
      .navBtn.active{
        background: rgba(0,0,0,.10);
        color: rgba(11,12,16,.96);
      }
      .navBtn svg{
        width:18px;
        height:18px;
        stroke: currentColor;
        stroke-width:2.2;
        fill:none;
        stroke-linecap:round;
        stroke-linejoin:round;
      }
      .navIcon{
        width:18px;
        height:18px;
        display:block;
        object-fit:contain;
      }

      /* ===== Page ===== */
      .wrap{
        max-width: 920px;
        margin: 0 auto;
        padding: 28px 20px 40px;
      }

      h1{
        font-size: 24px;
        margin: 0 0 10px;
        line-height: 1.2;
      }
      h2{
        font-size: 18px;
        margin: 22px 0 8px;
        line-height: 1.3;
      }
      h3{
        font-size: 16px;
        margin: 16px 0 6px;
        line-height: 1.35;
      }
      p, li{
        font-size: 15px;
      }
      ul, ol{
        padding-left: 18px;
      }
      .meta{
        font-size: 13px;
        opacity: 0.8;
        margin-bottom: 18px;
      }
      hr{
        border: 0;
        border-top: 1px solid #eaeaea;
        margin: 18px 0;
      }

      /* ===== Footer ===== */
      .footer{
        max-width: 920px;
        margin: 0 auto;
        padding: 0 20px 40px;
        color: rgba(11,12,16,.62);
        font-size: 13px;
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 14px;
        flex-wrap: wrap;
      }
      .links{
        display:flex;
        gap: 14px;
        flex-wrap: wrap;
      }
      .links a{
        color: rgba(11,12,16,.62);
        text-decoration:none;
      }
      .links a:hover{
        color: rgba(11,12,16,.90);
      }

      @media (prefers-color-scheme: dark) {
        :root { color-scheme: light; }
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <div class="topbarInner">
        <a class="brand" href="/" aria-label="FLY Unlimited">
          <img class="mascot" src="/logo-alt.png" alt="FLY mascot" />
        </a>

        <nav class="nav" aria-label="Navigation">
          <a class="navBtn" href="/" aria-label="Home" title="Home">
            <img class="navIcon" src="/flyhome.svg" alt="" aria-hidden="true" />
          </a>

          <a class="navBtn" href="/how-it-works/" aria-label="How it works" title="How it works">
            <img class="navIcon" src="/flyinactive.svg" alt="" aria-hidden="true" />
          </a>

          <a class="navBtn" href="/info/" aria-label="Info" title="Info">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 10.6v6" />
              <path d="M12 7.4h.01" />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <div class="wrap">
      <h1>{title}</h1>

      <div class="meta">
        <div><strong>Effective Date:</strong> {effectiveDate}</div>
        <div><strong>Operator:</strong> FLY Unlimited, LLC (registered in Delaware, United States)</div>
        <div><strong>Contact:</strong> <a href={`mailto:${contactEmail}`}>{contactEmail}</a></div>
      </div>

      <p>
        This Privacy Policy explains how we collect, use, share, and protect information when you use the FLY Unlimited
        mobile application and related services (the “Service”).
      </p>

      <h2>1) Information we collect</h2>

      <h3>A. Information you provide</h3>
      <ul>
        <li><strong>Account information:</strong> email address, phone number, username, name, profile photo, and password (stored as a secure hash).</li>
        <li><strong>User-generated content:</strong> posts, comments, likes, images, videos, and any documents/files you upload or share.</li>
        <li><strong>Direct messages:</strong> messages and attachments you send to other users.</li>
        <li><strong>Support communications:</strong> information you provide when contacting us.</li>
      </ul>

      <h3>B. Payments and payouts (Stripe)</h3>
      <p>
        The Service supports payments and payouts related to real-world/offline services. Payment processing and payout onboarding are handled by Stripe.
      </p>
      <ul>
        <li>We do <strong>not</strong> store full payment card numbers.</li>
        <li>
          We may store <strong>limited payment metadata</strong> required to run the Service, such as transaction amounts, timestamps,
          payout status, dispute/refund status, and identifiers provided by Stripe (for example, customer/payment intent/transfer identifiers).
        </li>
      </ul>

      <h3>C. Location information</h3>
      <p>
        The Service may request <strong>precise location</strong> permissions to provide location-based features (such as maps, nearby discovery, and related experiences).
        If you allow location access, we collect precise location while you use relevant features.
      </p>
      <p>
        If you do not enable location permissions, we may still infer approximate location from IP address for security, fraud prevention, and general operations.
      </p>

      <h3>D. Push notifications</h3>
      <p>
        If you enable push notifications, we collect and store a <strong>push notification token</strong> (and related routing information) so we can deliver notifications to your device.
        You can control notifications in your device settings.
      </p>

      <h3>E. Device, app, and usage information</h3>
      <p>
        We may collect device and app information (such as device type, OS version, app version, and language), usage and log data (timestamps, feature usage, and basic diagnostics),
        IP address, and related security signals to operate the Service, prevent abuse, and improve reliability.
      </p>

      <h3>F. Microphone access</h3>
      <p>
        The Service may request microphone permission for features that allow audio creation or sharing. Microphone access is used only when you choose to use an audio feature,
        and you can control microphone access in your device settings.
      </p>

      <h3>G. Analytics / crash reporting</h3>
      <p>
        At this time, we do <strong>not</strong> use third-party analytics or crash-reporting SDKs for tracking user behavior.
        If we add such tools in the future, we will update this Privacy Policy and any required in-app disclosures.
      </p>

      <h2>2) How we use information</h2>
      <p>
        We use information to provide and operate core features (accounts, profiles, posting, messaging, discovery), process payments and payouts,
        prevent fraud and abuse, moderate content and respond to user reports, provide support and service-related notices, and improve reliability.
      </p>

      <h2>3) How we share information</h2>
      <ul>
        <li><strong>Public content:</strong> the Service is a social network and posts are <strong>public by default</strong>. Public profile and public posts can be viewed by other users and may be viewable by the public depending on the Service and your settings.</li>
        <li><strong>Service providers:</strong> vendors who help us operate the Service (hosting, infrastructure, security, customer support).</li>
        <li><strong>Payments:</strong> payment and payout processing through Stripe.</li>
        <li><strong>Legal/safety:</strong> when reasonably necessary to comply with legal obligations, enforce our Terms, or protect users, the public, or the Service.</li>
        <li><strong>Business transfers:</strong> information may be transferred in a merger, acquisition, restructuring, financing, or sale of assets.</li>
      </ul>

      <h2>4) Direct messages and moderation</h2>
      <p>
        Direct messages are intended to be private between users. We do not routinely review private messages.
        However, we may access, review, or preserve messages when necessary to investigate reports, prevent abuse, comply with law, or enforce our Terms.
      </p>

      <h2>5) Content moderation</h2>
      <p>
        We provide tools to block and report users and content. Reports are reviewed manually at this time.
        We may remove content and take enforcement actions (warnings, suspensions, or account removal) to keep the community safe and enforce our policies.
      </p>

      <h2>6) Data retention</h2>
      <p>
        We retain information only as long as reasonably necessary to provide the Service, comply with legal and accounting obligations (including payment-related requirements),
        resolve disputes, maintain security, prevent abuse, and enforce our Terms.
      </p>

      <h2>7) Account deletion</h2>
      <p>
        You can delete your account within the app. When you delete your account, we take steps to delete or de-identify your account data.
        We may retain certain information where required or permitted for legal, security, fraud-prevention, or accounting purposes
        (for example, transaction records and related dispute/chargeback documentation).
      </p>

      <h2>8) Age requirement</h2>
      <p>
        The Service is intended for users <strong>16 years of age or older</strong>. By using the Service, you represent that you are at least 16.
        If we learn that someone under 16 is using the Service, we will take steps to disable the account and delete information as appropriate.
      </p>

      <h2>9) Security</h2>
      <p>We use reasonable safeguards designed to protect information. No system is completely secure.</p>

      <h2>10) Changes</h2>
      <p>
        We may update this Privacy Policy from time to time. We will update the effective date when changes are made.
        If changes are material, we may provide additional notice in the app.
      </p>

      <h2>11) Contact</h2>
      <p>
        For privacy questions or requests:
        <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
      </p>

      <hr />
      <p style="font-size:13px;opacity:.75;margin:0;">© 2026 FLY Unlimited, LLC</p>
    </div>

    <footer class="footer" aria-label="Footer">
      <div>© 2026 {siteName}</div>
      <div class="links">
        <a href="/">Home</a>
        <a href="/how-it-works/">How it works</a>
        <a href="/info/">Info</a>
        <a href="/terms/">Terms</a>
        <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
      </div>
    </footer>
  </body>
</html>
